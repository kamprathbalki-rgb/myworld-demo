<!DOCTYPE html>
<html>

<head>

<title>My Properties</title>

<meta
name="viewport"
content="width=device-width, initial-scale=1.0"
>

<style>

/* ================================
   PAGE
================================ */

*{
    box-sizing:border-box;
}

body{
    font-family:Arial,sans-serif;
    background:#f5f7fa;
    margin:0;
    padding:12px;
    color:#222;
}

.container{
    max-width:700px;
    margin:auto;
}


/* ================================
   HEADER
================================ */

.page-header{
    background:#1f4e79;
    color:white;

    padding:15px;
    border-radius:12px;
    margin-bottom:15px;

    display:flex;
    align-items:center;
    justify-content:space-between;

    box-shadow:0 2px 8px rgba(0,0,0,.15);
}

.page-header h2{
    margin:0;
    font-size:19px;
}

.back-btn{
    color:white;
    text-decoration:none;
    font-size:24px;
    width:30px;
}

.home-btn{
    color:white;
    text-decoration:none;
    font-size:22px;
    width:30px;
    text-align:right;
}


/* ================================
   SUMMARY
================================ */

.property-summary{
    background:white;

    border-radius:12px;
    padding:14px 16px;
    margin-bottom:15px;

    display:flex;
    align-items:center;
    justify-content:space-between;

    box-shadow:0 1px 5px rgba(0,0,0,.08);
}

.summary-title{
    color:#1f4e79;
    font-weight:bold;
    font-size:15px;
}

.summary-count{
    background:#1f4e79;
    color:white;

    min-width:40px;
    height:32px;

    padding:0 12px;
    border-radius:18px;

    display:flex;
    align-items:center;
    justify-content:center;

    font-weight:bold;
}


/* ================================
   MAP BUTTON
================================ */

.map-btn{
    display:flex;
    align-items:center;
    justify-content:center;

    width:100%;

    background:white;
    color:#1f4e79;

    border:1px solid #1f4e79;
    border-radius:10px;

    padding:12px;
    margin-bottom:15px;

    text-decoration:none;
    font-size:14px;
    font-weight:bold;

    box-shadow:0 1px 5px rgba(0,0,0,.06);
}


/* ================================
   PROPERTY LIST
================================ */

.property-list{
    display:flex;
    flex-direction:column;
    gap:12px;
}


/* ================================
   PROPERTY CARD
================================ */

.property-card{
    background:white;

    border-radius:12px;
    overflow:hidden;

    border-left:5px solid #1f4e79;

    box-shadow:0 1px 6px rgba(0,0,0,.10);
}


/* ================================
   PROPERTY HEADER
================================ */

.property-header{
    padding:15px;

    display:flex;
    justify-content:space-between;
    align-items:flex-start;

    gap:10px;

    border-bottom:1px solid #eee;
}

.project-name{
    font-size:17px;
    font-weight:bold;
    color:#1f4e79;

    line-height:1.3;
}

.property-location{
    margin-top:6px;

    font-size:13px;
    color:#555;

    line-height:1.4;
}


/* ================================
   STATUS
================================ */

.status-badge{
    padding:7px 10px;

    border-radius:16px;

    background:#e8f5e9;
    color:#2e7d32;

    font-size:11px;
    font-weight:bold;

    white-space:nowrap;
}


/* ================================
   PROPERTY DETAILS
================================ */

.property-body{
    padding:15px;
}

.property-grid{
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:10px;
}

.property-item{
    background:#f5f7fa;

    border-radius:9px;
    padding:11px;
}

.property-label{
    font-size:11px;
    color:#777;

    margin-bottom:6px;
}

.property-value{
    font-size:14px;
    font-weight:bold;

    color:#1f4e79;

    line-height:1.4;
}


/* ================================
   EMPTY STATE
================================ */

.empty-state{
    background:white;

    border-radius:12px;
    padding:35px 20px;

    text-align:center;

    box-shadow:0 1px 5px rgba(0,0,0,.08);
}

.empty-icon{
    font-size:40px;

    margin-bottom:12px;
}

.empty-title{
    font-size:17px;
    font-weight:bold;

    color:#1f4e79;

    margin-bottom:6px;
}

.empty-text{
    font-size:13px;
    color:#777;
}


/* ================================
   MOBILE
================================ */

@media(max-width:480px){

    body{
        padding:10px;
    }

    .page-header{
        padding:13px;
    }

    .page-header h2{
        font-size:17px;
    }

    .property-header{
        padding:13px;
    }

    .property-body{
        padding:13px;
    }

    .project-name{
        font-size:16px;
    }

}


@media(max-width:340px){

    .property-grid{
        grid-template-columns:1fr;
    }

}

</style>

</head>


<body>


<div class="container">


<!-- ================================
     HEADER
================================ -->


<div class="page-header">


    <a
        href="javascript:history.back()"
        class="back-btn"
    >
        ←
    </a>


    <h2>
        🏢 My Properties
    </h2>


    <a
        href="/executive/dashboard"
        class="home-btn"
    >
        🏠
    </a>


</div>



<!-- ================================
     PROPERTY SUMMARY
================================ -->


<div class="property-summary">


    <div class="summary-title">

        🏢 Available Properties

    </div>


    <div class="summary-count">

        <%= properties ? properties.length : 0 %>

    </div>


</div>



<!-- ================================
     PROPERTY MAP
================================ -->


<a
    href="/executive/property-map"
    class="map-btn"
>

    🗺️ View Properties on Map

</a>



<!-- ================================
     PROPERTY CARDS
================================ -->


<% if (properties && properties.length > 0) { %>


<div class="property-list">


<% properties.forEach(function(p){ %>


<div class="property-card">


    <!-- PROPERTY HEADER -->


    <div class="property-header">


        <div>


            <div class="project-name">

                🏢
                <%= p.projectName || 'Project' %>

            </div>


            <div class="property-location">

                📍
                <%= p.propertyLocation || '-' %>

            </div>


        </div>



        <div class="status-badge">

            <%= p.propertyStatus || 'Available' %>

        </div>


    </div>



    <!-- PROPERTY DETAILS -->


    <div class="property-body">


        <div class="property-grid">


            <div class="property-item">


                <div class="property-label">

                    🏠 Property Type

                </div>


                <div class="property-value">

                    <%= p.singleFlatType || '-' %>

                </div>


            </div>



            <div class="property-item">


                <div class="property-label">

                    💰 Quoted Price

                </div>


                <div class="property-value">

                    <%= p.singleQuotedPrice || 0 %>

                </div>


            </div>


        </div>


    </div>


</div>


<% }) %>


</div>


<% } else { %>



<!-- ================================
     EMPTY STATE
================================ -->


<div class="empty-state">


    <div class="empty-icon">

        🏢

    </div>


    <div class="empty-title">

        No Properties Available

    </div>


    <div class="empty-text">

        There are currently no properties
        available to display.

    </div>


</div>


<% } %>


</div>


</body>

</html>