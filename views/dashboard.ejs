<!DOCTYPE html>

<html>

<head>

<meta charset="UTF-8">

<meta
    name="viewport"
    content="width=device-width, initial-scale=1.0">

<title>MyWorld Dashboard</title>

<style>

*{
    box-sizing:border-box;
}

body{
    margin:0;
    padding:20px;
    font-family:Arial,sans-serif;
    background:#f5f7fa;
}

.container{
    max-width:1400px;
    margin:auto;
}


/* ================================
   HEADER
================================ */

.header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    flex-wrap:wrap;
    gap:15px;
    margin-bottom:20px;

    position:sticky;
    top:0;

    background:#f5f7fa;

    padding:10px 0;

    z-index:100;
}

.header h1{
    margin:0;
    color:#1f4e79;
}

.logout{
    text-decoration:none;
    background:#d9534f;
    color:white;
    padding:10px 16px;
    border-radius:6px;
    font-weight:bold;
}

.logout:hover{
    background:#c9302c;
}

.welcome{
    background:white;
    padding:15px 20px;
    border-radius:10px;
    box-shadow:0 2px 8px rgba(0,0,0,.1);
}


/* ================================
   SECTION
================================ */

.section-card{
    background:white;
    padding:20px;
    border-radius:10px;
    box-shadow:0 2px 8px rgba(0,0,0,.1);
    margin-bottom:25px;
}

.section-title{
    margin-top:0;
    color:#1f4e79;
}


/* ================================
   SUMMARY GRID
================================ */

.summary{
    display:grid;
    grid-template-columns:
    repeat(auto-fit,minmax(180px,1fr));
    gap:15px;
}

.summary a{
    text-decoration:none;
    color:inherit;
}


/* ================================
   CARDS
================================ */

.card{
    background:white;
    border-radius:10px;
    padding:20px;
    text-align:center;
    box-shadow:0 2px 8px rgba(0,0,0,.1);
    border:1px solid #ddd;

    min-height:140px;

    display:flex;
    flex-direction:column;
    justify-content:center;
}

.card h3{
    margin:0;
    color:#666;
    font-size:14px;
    text-transform:uppercase;
    letter-spacing:1px;
}

.card h2{
    margin-top:12px;
    margin-bottom:0;
    color:#1f4e79;
    font-size:32px;
    font-weight:bold;
}

.summary .card:hover{
    transform:translateY(-2px);
    transition:.2s;
    cursor:pointer;
}


/* ================================
   PRIORITY CARDS
================================ */

.followup-card{
    border-top:4px solid #dc3545;
}

.negotiation-card{
    border-top:4px solid #6f42c1;
}

.visit-card{
    border-top:4px solid #fd7e14;
}

.closed-card{
    border-top:4px solid #28a745;
}

.token-card{
    border-top:4px solid #ffc107;
}


/* ================================
   SECONDARY CARDS
================================ */

.property-card{
    border-top:4px solid #1f4e79;
}

.buyer-card{
    border-top:4px solid #28a745;
}

.executive-card{
    border-top:4px solid #6f42c1;
}


/* ================================
   QUICK ACTIONS
================================ */

.actions{
    display:grid;
    grid-template-columns:
    repeat(auto-fit,minmax(180px,1fr));
    gap:15px;
    margin-top:20px;
}

.action-btn{
    display:block;
    text-align:center;
    background:#1f4e79;
    color:white;
    padding:18px;
    border-radius:10px;
    text-decoration:none;
    font-weight:bold;
    font-size:16px;
}

.action-btn:hover{
    background:#163b5d;
    transition:.2s;
    transform:translateY(-2px);
}


/* ================================
   TOOLS
================================ */

.navbar{
    display:grid;
    grid-template-columns:
    repeat(auto-fit,minmax(180px,1fr));
    gap:15px;
    margin-top:20px;
}

.navbar a{
    display:block;
    text-align:center;
    background:#555;
    color:white;
    padding:18px;
    border-radius:10px;
    text-decoration:none;
    font-weight:bold;
    font-size:16px;
}

.navbar a:hover{
    background:#444;
    transition:.2s;
    transform:translateY(-2px);
}


/* ================================
   DASHBOARD FLOATERS
================================ */

.dashboard-floaters{
    position:fixed;

    right:20px;
    bottom:20px;

    z-index:1000;

    display:flex;
    flex-direction:column;

    gap:12px;
}


/* ================================
   FLOATER ITEM
================================ */

.floater-item{
    position:relative;

    display:flex;

    justify-content:flex-end;
    align-items:center;
}


/* ================================
   FLOATING BUTTON
================================ */

.floater-btn{
    width:56px;
    height:56px;

    border:none;

    border-radius:50%;

    display:flex;
    align-items:center;
    justify-content:center;

    font-size:24px;

    cursor:pointer;

    box-shadow:
        0 4px 12px rgba(0,0,0,.25),
        0 0 0 3px white;
}


/* ADMIN */

.admin-float-btn{
    background:#555;
    color:white;
}


/* BULK UPLOAD */

.bulk-float-btn{
    background:#1f4e79;
    color:white;
}


/* WHATSAPP */

.whatsapp-float-btn{
    background:#25D366;
    color:white;
}


/* ================================
   FLOATING MENU
================================ */

.floater-menu{
    display:none;

    position:absolute;

    right:70px;
    bottom:0;

    width:230px;

    padding:8px;

    background:white;

    border-radius:12px;

    box-shadow:
        0 4px 18px
        rgba(0,0,0,.20);
}


/* SHOW */

.floater-menu.show{
    display:block;
}


/* ================================
   MENU TITLE
================================ */

.floater-menu-title{
    padding:9px 10px;

    color:#1f4e79;

    font-size:13px;
    font-weight:bold;

    border-bottom:1px solid #eee;

    margin-bottom:4px;
}


/* ================================
   MENU LINKS
================================ */

.floater-menu a{
    display:block;

    padding:11px 10px;

    color:#333;

    text-decoration:none;

    font-size:13px;
    font-weight:bold;

    border-radius:8px;
}

.floater-menu a:hover{
    background:#f2f5f7;
}


/* ================================
   MOBILE
================================ */

@media(max-width:600px){

    body{
        padding:10px;
    }

.header{
    position:relative;
    padding:5px 0;
    display:flex;
    flex-wrap:wrap;
    gap:10px;
}

    .header h1{
        font-size:21px;
    }

    .header > div:first-child p{
        font-size:13px;
    }

.welcome{
    flex:1 1 100%;
    width:100%;
    max-width:100%;
    order:3;
    padding:12px 15px;
}

    .welcome h3{
        font-size:15px;
    }

    .welcome p{
        font-size:12px;
    }

    .logout{
        padding:9px 12px;
        font-size:13px;
    }

    .section-card{
        padding:12px;
    }

    .summary{
        grid-template-columns:
        repeat(2,1fr);

        gap:10px;
    }

    .card{
        min-height:115px;
        padding:12px 8px;
    }

    .card h3{
        font-size:11px;
        letter-spacing:.4px;
        line-height:1.4;
    }

    .card h2{
        font-size:23px;
        margin-top:9px;
    }

    .actions{
        grid-template-columns:
        repeat(2,1fr);

        gap:10px;
    }

    .action-btn{
        padding:15px 8px;
        font-size:13px;
    }

    .navbar{
        grid-template-columns:
        repeat(2,1fr);

        gap:10px;
    }

    .navbar a{
        padding:15px 8px;
        font-size:13px;
    }

    .dashboard-floaters{
        right:14px;
        bottom:14px;

        gap:10px;
    }

    .floater-btn{
        width:52px;
        height:52px;

        font-size:22px;
    }

    .floater-menu{
        right:62px;

        width:220px;

        max-width:
        calc(100vw - 90px);
    }

}


/* ================================
   VERY SMALL MOBILE
================================ */

@media(max-width:360px){

    .summary{
        grid-template-columns:1fr 1fr;
    }

    .card h2{
        font-size:20px;
    }

}

/* ================================
   PRIORITY DASHBOARD ENHANCEMENT
================================ */

.priority-negotiation-full{
    grid-column:1 / -1;
}

.priority-grid{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:15px;
}

.priority-grid a{
    text-decoration:none;
    color:inherit;
}


/* FIRST THREE OPERATIONAL CARDS */

.priority-operational{
    min-height:175px;
    padding:24px 20px;

    position:relative;

    display:flex;
    flex-direction:column;
    align-items:center;
    justify-content:center;

    border-radius:12px;

    background:white;

    box-shadow:0 3px 10px rgba(0,0,0,.10);
}

.priority-operational h3{
    margin:0;

    font-size:14px;

    color:#555;

    text-transform:uppercase;

    letter-spacing:.7px;
}

.priority-operational h2{
    margin:12px 0 7px;

    font-size:42px;

    color:#1f4e79;
}

.priority-story{
    margin:0;

    font-size:12px;

    color:#777;

    text-align:center;
}


/* FOLLOW UP */

.priority-followup{
    border-top:5px solid #dc3545;
}


/* NEGOTIATION */

.priority-negotiation{
    border-top:5px solid #6f42c1;
}


/* SITE VISIT */

.priority-visit{
    border-top:5px solid #fd7e14;
}


/* RESULT ROW */

.priority-results{
    grid-column:1 / -1;

    display:grid;

    grid-template-columns:1fr 1fr;

    gap:15px;
}


/* RESULT CARDS */

.priority-result-card{
    min-height:125px;

    padding:18px;

    border-radius:12px;

    background:white;

    display:flex;

    align-items:center;

    justify-content:space-between;

    gap:15px;

    box-shadow:0 2px 8px rgba(0,0,0,.08);
}

.priority-result-info h3{
    margin:0 0 7px;

    color:#555;

    font-size:13px;

    text-transform:uppercase;

    letter-spacing:.5px;
}

.priority-result-info p{
    margin:0;

    color:#777;

    font-size:12px;
}

.priority-result-value{
    text-align:right;
}

.priority-result-count{
    font-size:28px;

    font-weight:bold;

    color:#1f4e79;
}

.priority-result-money{
    margin-top:5px;

    font-size:16px;

    font-weight:bold;

    color:#28a745;
}

/* FOLLOWUPS */

.priority-followup{
    border-left:5px solid #dc3545;
}

/* SITE VISITS */

.priority-visit{
    border-left:5px solid #fd7e14;
}

/* CLOSED */

.priority-closed{
    border-left:5px solid #28a745;
}


/* TOKEN */

.priority-token{
    border-left:5px solid #ffc107;
}


/* HOVER */

.priority-operational:hover,
.priority-result-card:hover{
    transform:translateY(-2px);

    transition:.2s;

    cursor:pointer;
}


/* ================================
   PRIORITY MOBILE
================================ */

@media(max-width:600px){

    .priority-grid{
        grid-template-columns:1fr;

        gap:10px;
    }

    .priority-operational{
        min-height:135px;

        padding:18px;
    }

    .priority-operational h3{
        font-size:12px;
    }

    .priority-operational h2{
        margin:8px 0 5px;

        font-size:36px;
    }

    .priority-story{
        font-size:11px;
    }

    .priority-results{
        grid-column:auto;

        grid-template-columns:1fr 1fr;

        gap:10px;
    }

    .priority-result-card{
        min-height:125px;

        padding:13px;

        display:block;

        text-align:center;

        border-left:none;
    }

    .priority-closed{
        border-top:4px solid #28a745;
    }

    .priority-token{
        border-top:4px solid #ffc107;
    }

    .priority-result-info h3{
        font-size:11px;

        line-height:1.4;
    }

    .priority-result-info p{
        font-size:10px;
    }

    .priority-result-value{
        margin-top:9px;

        text-align:center;
    }

    .priority-result-count{
        font-size:25px;
    }

    .priority-result-money{
        font-size:13px;
    }

}

/* ================================
   ADMIN SUBSCRIPTION INFO
================================ */

.admin-subscription{
    margin-top:6px;
    padding:10px;

    border-top:1px solid #eee;

    background:#f8f9fa;

    border-radius:8px;
}

.admin-subscription-title{
    margin-bottom:9px;

    color:#1f4e79;

    font-size:12px;
    font-weight:bold;
}

.admin-subscription-row{
    display:flex;

    justify-content:space-between;

    gap:10px;

    padding:5px 0;

    color:#666;

    font-size:11px;
}

.admin-subscription-row strong{
    color:#333;

    text-align:right;
}


/* ================================
   SUBSCRIPTION FOOTER
================================ */

.subscription-footer{
    margin-top:20px;
    margin-bottom:90px;

    padding:10px 15px;

    border-radius:8px;

    text-align:center;

    font-size:12px;
    font-weight:bold;
}


/* ACTIVE */

.subscription-active{
    background:#e8f5e9;
    color:#2e7d32;
    border:1px solid #c8e6c9;
}


/* LESS THAN OR EQUAL TO 30 DAYS */

.subscription-warning{
    background:#fff8e1;
    color:#8a6d00;
    border:1px solid #ffe082;
}


/* 1 TO 3 DAYS */

.subscription-urgent{
    background:#ffebee;
    color:#c62828;
    border:1px solid #ffcdd2;
}


/* EXPIRED */

.subscription-expired{
    background:#ffebee;
    color:#b71c1c;
    border:1px solid #ef9a9a;
}

/* ================================
   DASHBOARD DATE & TIME
================================ */

.dashboard-datetime{
    display:flex;
    align-items:center;
    gap:18px;

    margin-top:10px;

    padding-top:10px;

    border-top:1px solid #eee;

    color:#1f4e79;

    font-size:13px;
    font-weight:bold;
}


/* MOBILE */

@media(max-width:600px){

    .header > div:first-child{
        width:100%;
    }

    .header > div:first-child p{
        font-size:13px;
    }
}

.logout-float-btn{
    width:48px;
    height:48px;
    font-size:20px;
    background:#d9534f;
    color:white;
}

.logout-float-btn:hover{
    background:#c9302c;
}

.download-float-btn{
    background:#198754;
    color:white;
}

</style>

</head>

<body>

<div class="container">

<!-- ================================
     HEADER
================================ -->

<div class="header">

<div class="welcome">

<h3 style="margin:0;">
Welcome to MyWorld CRM
</h3>

<p style="margin-top:8px;color:#666;">
Manage Properties, Buyers, Executives and Follow Ups
</p>

<div class="dashboard-datetime">

    <span>
        📅 <span id="dashboardDate"></span>
    </span>

    <span>
        🕐 <span id="dashboardTime"></span>
    </span>

</div>

</div>

</div>

<!-- ================================
     PRIORITY DASHBOARD
================================ -->

<div class="section-card">

<div class="priority-grid">



<!-- ================================
     NEGOTIATION
================================ -->

<div class="
    priority-operational
    priority-negotiation
    priority-negotiation-full
">

<h3>
🤝 Negotiation
</h3>

<h2>
<%= negotiation %>
</h2>

<p class="priority-story">
Active opportunities
</p>

</div>


<!-- ================================
     RESULT CARDS
================================ -->

<div class="priority-results">

<a href="/dashboard/followups">

<div class="
    priority-result-card
    priority-followup
">

    <div class="priority-result-info">
        <h3>📞 Today's Follow Ups</h3>
        <p>Needs attention today</p>
    </div>

    <div class="priority-result-value">
        <div class="priority-result-count">
            <%= followUps %>
        </div>
    </div>

</div>

</a>

<a href="/dashboard/sitevisits">

<div class="
    priority-result-card
    priority-visit
">

    <div class="priority-result-info">
        <h3>🚗 Today's Site Visits</h3>
        <p>Visits scheduled today</p>
    </div>

    <div class="priority-result-value">
        <div class="priority-result-count">
            <%= visits %>
        </div>
    </div>

</div>

</a>


<!-- CLOSED THIS MONTH -->

<div class="
    priority-result-card
    priority-closed
">

<div class="priority-result-info">

<h3>
🏆 Closed This Month
</h3>

<p>
Successful conversions
</p>

</div>


<div class="priority-result-value">

<div class="priority-result-count">
<%= closedCount %>
</div>

<div class="priority-result-money">
₹ <%= closedValue.toLocaleString('en-IN') %>
</div>

</div>

</div>



<!-- TOKEN RECEIVED -->

<a href="/property/token">

<div class="
    priority-result-card
    priority-token
">

<div class="priority-result-info">

<h3>
🪙 Token Received
</h3>

<p>
Properties with token
</p>

</div>


<div class="priority-result-value">

<div class="priority-result-count">
<%= tokenProperties || 0 %>
</div>

</div>

</div>

</a>


</div>


</div>


</div>

<!-- ================================
     BUSINESS OVERVIEW
================================ -->

<div class="section-card">

<h2 class="section-title">
Business Overview
</h2>

<div class="summary">


<!-- PROPERTIES -->

<a href="/property/page">

<div class="card property-card">

<h3>
Properties
</h3>

<h2>
<%= properties %>
</h2>

</div>


</a>


<!-- SOLD PROPERTIES -->

<a href="/property/sold">

<div class="card">

<h3>
Sold Properties
</h3>

<h2>
<%= soldProperties || 0 %>
</h2>

</div>

</a>


<!-- BUYERS -->

<a href="/buyer/page">

<div class="card buyer-card">

<h3>
Buyers
</h3>

<h2>
<%= buyers %>
</h2>

</div>

</a>


<!-- CONTACTED -->

<div class="card">

<h3>
Contacted
</h3>

<h2>
<%= contacted %>
</h2>

</div>


<!-- PIPELINE -->

<div class="card">

<h3>
Pipeline
(<%= pipelineCount %>)
</h3>

<h2>
₹ <%= pipelineValue.toLocaleString('en-IN') %>
</h2>

</div>


<!-- LOST -->

<div class="card">

<h3>
Lost
(<%= lostCount %>)
</h3>

<h2>
₹ <%= lostValue.toLocaleString('en-IN') %>
</h2>

</div>

</div>

<div class="section-card">

<h2 class="section-title">
Lead Aging
</h2>

<%
const sections = [

    // Follow-Up Required
    ["🔴 Overdue",
        leadGroups.followUpRequired.overdue],

    ["🟠 Today",
        leadGroups.followUpRequired.today],

    ["🟡 1 - 3 Days",
        leadGroups.followUpRequired.oneToThree],

    ["🟢 4 - 7 Days",
        leadGroups.followUpRequired.fourToSeven],

    ["🔵 8+ Days",
        leadGroups.followUpRequired.eightPlus],

    // No Follow-Up Assigned
    ["🆕 New (0 - 3 Days)",
        leadGroups.noFollowUpAssigned.new],

    ["🟨 4 - 7 Days",
        leadGroups.noFollowUpAssigned.fourToSeven],

    ["🟧 8 - 15 Days",
        leadGroups.noFollowUpAssigned.eightToFifteen],

    ["🟥 15+ Days",
        leadGroups.noFollowUpAssigned.moreThanFifteen]

];
%>

<% sections.forEach(([title, buyers]) => { %>

<details style="margin-bottom:15px;" <%= buyers.length ? "open" : "" %>>

<summary style="
padding:12px;
background:#f5f7fa;
font-weight:bold;
cursor:pointer;
border-radius:8px;
">
<%= title %> (<%= buyers.length %>)
</summary>

<% buyers.forEach(function(buyer){ %>

<div style="
padding:12px;
margin:8px 0;
border:1px solid #ddd;
border-radius:8px;
background:#fff;
">

<b><%= buyer.name %></b><br>

<%= buyer.mobile || "" %><br>

Status :
<%= buyer.status %><br>

Follow Up :
<%= buyer.nextFollowUp
? buyer.nextFollowUp.toLocaleDateString("en-IN")
: "-" %>

<br><br>

<a href="/buyer/edit/<%= buyer._id %>">
Edit
</a>

</div>

<% }) %>

</details>

<% }) %>

</div>



</div>





<!-- ================================
     QUICK ACTIONS
================================ -->

<div class="section-card">


<h2 class="section-title">
Quick Actions
</h2>


<div class="actions">


<a
href="/property/add-builder"
class="action-btn"
>
Builder Project
</a>


<a
href="/property/add-single"
class="action-btn"
>
Single Property
</a>


<a
href="/buyer/add"
class="action-btn"
>
Buyer
</a>

<a
href="/dashboard/executive-status"
class="action-btn"
>
👥 Executive Status
</a>

<a href="/photo-gallery" class="action-btn">
    📷 Photo Gallery
</a>

</div>


</div>


<!-- ================================
     TOOLS
================================ -->

<div class="section-card">


<h2 class="section-title">
Tools
</h2>


<div class="navbar">


<a href="/attendance/admin">
Attendance
</a>


<a href="/property/map-view">
Map
</a>


<a href="/dashboard/demand-prediction">
Demand Prediction
</a>


<a href="/dashboard/intelligence">
Market Intelligence
</a>


<a href="/dashboard/hot-locations">
Hot Locations
</a>


<a href="/dashboard/investment-opportunities">
Investment Opportunities
</a>


</div>


</div>

<!-- ================================
     SUBSCRIPTION STATUS FOOTER
================================ -->

<% if (daysRemaining <= 0) { %>

<div class="
subscription-footer
subscription-expired
">
🔴 Subscription Expired
</div>


<% } else if (daysRemaining <= 3) { %>

<div class="
subscription-footer
subscription-urgent
">
🔴 Subscription expires in
<%= daysRemaining %>
day<%= daysRemaining === 1 ? '' : 's' %>
</div>


<% } else if (daysRemaining <= 30) { %>

<div class="
subscription-footer
subscription-warning
">
