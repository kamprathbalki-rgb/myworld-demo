<script>

function toggleFloatMenu(menuId){

    const menus =
    document.querySelectorAll(
        '.floater-menu'
    )

    menus.forEach(function(menu){

        if(menu.id !== menuId){
            menu.classList.remove('show')
        }

    })

    const selectedMenu =
    document.getElementById(menuId)

    selectedMenu.classList.toggle('show')

}

</script>

</div>

<script>

function updateDashboardDateTime(){

    const now = new Date()


    const dateOptions = {
        weekday:'short',
        day:'2-digit',
        month:'short',
        year:'numeric'
    }


    const timeOptions = {
        hour:'2-digit',
        minute:'2-digit',
        second:'2-digit',
        hour12:true
    }


    document.getElementById(
        'dashboardDate'
    ).textContent =
    now.toLocaleDateString(
        'en-IN',
        dateOptions
    )


    document.getElementById(
        'dashboardTime'
    ).textContent =
    now.toLocaleTimeString(
        'en-IN',
        timeOptions
    )

}


updateDashboardDateTime()


setInterval(
    updateDashboardDateTime,
    1000
)

</script>

