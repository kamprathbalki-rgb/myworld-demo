<!DOCTYPE html>
<html>

<head>

<title>AI Property Price Estimator</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#f4f6f9;
}

.card{
padding:25px;
background:white;
border-radius:10px;
box-shadow:0 2px 6px rgba(0,0,0,0.1);
}

</style>

</head>

<body>

<div class="container">

<h2 class="my-4">AI Property Price Estimator</h2>

<div class="card">

<form method="POST" action="/dashboard/price-estimator">

<div class="mb-3">
<label>City</label>
<input type="text" name="city" class="form-control" required>
</div>

<div class="mb-3">
<label>Area (sq.ft)</label>
<input type="number" name="area" class="form-control" required>
</div>

<button class="btn btn-primary">Estimate Price</button>

</form>

<% if(typeof estimatedPrice !== 'undefined'){ %>

<hr>

<h4>Estimated Market Price</h4>

<h2 class="text-success">₹ <%= estimatedPrice %></h2>

<p>
Based on historical deals in <b><%= city %></b>
</p>

<% } %>

</div>

</div>

</body>

</html>