<script>

function showTab(tabId){

    document
    .getElementById(
        'apartmentTab'
    )
    .style
    .display =
    'none'


    document
    .getElementById(
        'otherTab'
    )
    .style
    .display =
    'none'


    document
    .getElementById(
        'apartmentTabButton'
    )
    .classList
    .remove(
        'active'
    )


    document
    .getElementById(
        'otherTabButton'
    )
    .classList
    .remove(
        'active'
    )


    document
    .getElementById(
        tabId
    )
    .style
    .display =
    'block'


    if(
        tabId ===
        'apartmentTab'
    ){

        document
        .getElementById(
            'apartmentTabButton'
        )
        .classList
        .add(
            'active'
        )

    }else{

        document
        .getElementById(
            'otherTabButton'
        )
        .classList
        .add(
            'active'
        )

    }

}

document.getElementById('addContactBtn').addEventListener('click', function () {

    const container = document.getElementById('builderContacts');

    const cards = container.querySelectorAll('.builder-contact-card');

    const newCard = cards[0].cloneNode(true);

    newCard.querySelectorAll('input').forEach(input => {

        if (input.type === 'radio') {
            input.checked = false;
            input.value = cards.length;
        } else {
            input.value = '';
        }

    });

    newCard.querySelectorAll('select').forEach(select => {
        select.selectedIndex = 0;
    });

    container.appendChild(newCard);

});

</script>



