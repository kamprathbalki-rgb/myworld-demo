<!DOCTYPE html>
<html>

<head>

<title>Subscription Expired</title>

<meta
name="viewport"
content="width=device-width, initial-scale=1.0"
>

<style>

/* ================================
   GLOBAL
================================ */

*{
    box-sizing:border-box;
}

html,
body{
    width:100%;
    height:100%;

    margin:0;
}

body{
    font-family:Arial,sans-serif;

    background:#f4f6f9;

    display:flex;

    align-items:center;

    justify-content:center;

    padding:20px;

    color:#222;
}


/* ================================
   CARD
================================ */

.expired-card{
    width:100%;

    max-width:480px;

    background:white;

    border-radius:16px;

    overflow:hidden;

    box-shadow:
        0 4px 18px
        rgba(0,0,0,.12);

    text-align:center;
}


/* ================================
   TOP WARNING
================================ */

.warning-header{
    background:#ffebee;

    padding:25px 20px;
}

.warning-icon{
    width:70px;
    height:70px;

    margin:auto;

    border-radius:50%;

    background:white;

    display:flex;

    align-items:center;

    justify-content:center;

    font-size:34px;

    box-shadow:
        0 2px 8px
        rgba(0,0,0,.08);
}


/* ================================
   CONTENT
================================ */

.expired-content{
    padding:25px;
}

.expired-title{
    color:#c62828;

    font-size:22px;

    font-weight:bold;

    margin-bottom:12px;
}

.expired-message{
    color:#555;

    font-size:14px;

    line-height:1.6;

    margin-bottom:20px;
}


/* ================================
   REDIRECT
================================ */

.redirect-box{
    background:#f5f7fa;

    border-radius:10px;

    padding:13px;

    color:#666;

    font-size:12px;

    line-height:1.5;

    margin-bottom:18px;
}

.redirect-icon{
    font-size:18px;

    margin-bottom:5px;
}


/* ================================
   LOGIN BUTTON
================================ */

.login-btn{
    display:block;

    width:100%;

    padding:13px;

    background:#1f4e79;

    color:white;

    border-radius:9px;

    text-decoration:none;

    font-size:14px;

    font-weight:bold;
}


/* ================================
   FOOTER
================================ */

.expired-footer{
    margin-top:18px;

    color:#999;

    font-size:11px;
}


/* ================================
   MOBILE
================================ */

@media(max-width:480px){

    body{
        padding:12px;
    }

    .expired-content{
        padding:22px 18px;
    }

    .expired-title{
        font-size:20px;
    }

}

</style>

</head>


<body>


<div class="expired-card">



<!-- ================================
     WARNING
================================ -->


<div class="warning-header">


    <div class="warning-icon">

        ⚠️

    </div>


</div>



<!-- ================================
     CONTENT
================================ -->


<div class="expired-content">


    <div class="expired-title">

        Subscription Expired

    </div>


    <div class="expired-message">

        Your company's subscription
        is no longer active.

        <br><br>

        Please contact your administrator
        to renew the subscription and
        restore access.

    </div>



    <!-- REDIRECT -->


    <div class="redirect-box">


        <div class="redirect-icon">

            ⏳

        </div>


        Redirecting to the login page
        in 5 seconds...


    </div>



    <!-- MANUAL LOGIN -->


    <a
        href="/login"
        class="login-btn"
    >

        🔐 Return to Login

    </a>



    <div class="expired-footer">

        Access will be restored after
        your subscription is renewed.

    </div>


</div>


</div>



<!-- ================================
     EXISTING REDIRECT FUNCTIONALITY
================================ -->


<script>


setTimeout(
    function(){


        window.location.href =
        '/login'


    },
    5000
)


</script>


</body>

</html>