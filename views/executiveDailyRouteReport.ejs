<!DOCTYPE html>
<html>

<head>

<title>Executive Daily Route Report</title>

<meta
name="viewport"
content="width=device-width, initial-scale=1.0"
>

<style>

body{
    font-family:Arial,sans-serif;
    background:#f5f7fa;
    margin:0;
    padding:12px;
    color:#222;
}

.container{
    max-width:700px;
    margin:auto;
}


/* ================================
   HEADER
================================ */

.page-header{
    background:#1f4e79;
    color:white;
    padding:15px;
    border-radius:12px;
    margin-bottom:15px;

    display:flex;
    align-items:center;
    justify-content:space-between;

    box-shadow:0 2px 8px rgba(0,0,0,.15);
}

.page-header h2{
    margin:0;
    font-size:19px;
}

.back-btn{
    color:white;
    text-decoration:none;
    font-size:24px;
    width:30px;
}

.header-spacer{
    width:30px;
}


/* ================================
   SUMMARY
================================ */

.summary{
    display:grid;
    grid-template-columns:repeat(2,1fr);
    gap:10px;
    margin-bottom:20px;
}

.card{
    background:white;
    border:none;
    border-radius:10px;
    padding:14px 10px;
    text-align:center;

    box-shadow:0 1px 5px rgba(0,0,0,.08);
}

.card h3{
    margin:0 0 7px;
    font-size:12px;
    color:#666;
}

.card h2{
    margin:0;
    font-size:17px;
    color:#1f4e79;
}


/* ================================
   SECTIONS
================================ */

.section{
    margin-top:20px;
}

.section h2{
    color:#1f4e79;
    font-size:17px;
    margin:0 0 10px;
}


/* ================================
   ROUTE MAP
================================ */

.route-box{
    background:white;
    padding:8px;
    border-radius:12px;

    box-shadow:0 1px 5px rgba(0,0,0,.08);
}

#routeMap{
    height:420px;
    width:100%;
    border-radius:8px;
}


/* ================================
   TABLES
================================ */

.table-scroll{
    width:100%;
    overflow-x:auto;

    background:white;
    border-radius:10px;

    box-shadow:0 1px 5px rgba(0,0,0,.08);
}

table{
    width:100%;
    border-collapse:collapse;
    margin:0;
}

table th,
table td{
    border-bottom:1px solid #eee;
    padding:10px;
    font-size:12px;
    text-align:left;
}

table th{
    background:#1f4e79;
    color:white;
    white-space:nowrap;
}


/* Timeline needs horizontal scroll */

.timeline-table{
    min-width:650px;
}

.timeline-table td{
    white-space:nowrap;
}


/* Timeline row indication */

.site{
    background:#fff8e1;
}

.client{
    background:#e3f2fd;
}

.login{
    background:#e8f5e9;
}

.logout{
    background:#ffebee;
}


/* ================================
   METRIC TABLES
================================ */

.metric-box{
    background:white;
    border-radius:10px;
    overflow:hidden;

    box-shadow:0 1px 5px rgba(0,0,0,.08);
}

.metric-table{
    min-width:0;
}

.metric-table td:first-child{
    font-weight:bold;
    color:#555;
}

.metric-table td:last-child{
    text-align:right;
    font-weight:bold;
    color:#1f4e79;
}


/* ================================
   MOBILE
================================ */

@media(max-width:480px){

    body{
        padding:10px;
    }

    .page-header{
        padding:13px;
    }

    .page-header h2{
        font-size:17px;
    }

    .card{
        padding:12px 8px;
    }

    .card h2{
        font-size:15px;
    }

    #routeMap{
        height:380px;
    }

}

</style>


<link
rel="stylesheet"
href="https://unpkg.com/leaflet/dist/leaflet.css"
/>

<script
src="https://unpkg.com/leaflet/dist/leaflet.js">
</script>


</head>


<body>


<div class="container">


<!-- ================================
     HEADER
================================ -->


<div class="page-header">

    <a
    href="javascript:history.back()"
    class="back-btn"
    >
        ←
    </a>

    <h2>
        🗺️ Daily Route
    </h2>

    <div class="header-spacer"></div>

</div>



<!-- ================================
     SUMMARY
================================ -->


<div class="summary">


    <div class="card">

        <h3>
            👤 Executive
        </h3>

        <h2>
            <%= attendance.executiveName %>
        </h2>

    </div>


    <div class="card">

        <h3>
            📅 Date
        </h3>

        <h2>
            <%= attendance.date %>
        </h2>

    </div>


    <div class="card">

        <h3>
            🏢 Site Visits
        </h3>

        <h2>
            <%= siteVisitCount %>
        </h2>

    </div>


    <div class="card">

        <h3>
            🤝 Client Meetings
        </h3>

        <h2>
            <%= clientVisitCount %>
        </h2>

    </div>


</div>



<!-- ================================
     ROUTE MAP
================================ -->


<div class="section">

    <h2>
        🗺️ Route Map
    </h2>


    <div class="route-box">

        <div id="routeMap"></div>

    </div>

</div>



<!-- ================================
     TIMELINE
================================ -->


<div class="section">

<h2>
    📍 Timeline
</h2>


<div class="table-scroll">


<table class="timeline-table">


<tr>

<th>#</th>

<th>Type</th>

<th>Time</th>

<th>Latitude</th>

<th>Longitude</th>

<th>Accuracy</th>

</tr>


<%

let rowNo = 1


if(attendance.loginLocations){

attendance.loginLocations.forEach(function(x){

%>


<tr class="login">

<td>
    #<%= rowNo++ %>
</td>

<td>
    🟢 LOGIN
</td>

<td>
    <%= x.time || '' %>
</td>

<td>
    <%= x.latitude || '' %>
</td>

<td>
    <%= x.longitude || '' %>
</td>

<td>
    <%= x.accuracy || '' %>
</td>

</tr>


<%

})

}



if(locationLogs){

locationLogs.forEach(function(x){

%>


<tr class="<%= x.type === 'SITE' ? 'site' : 'client' %>">


<td>
    #<%= rowNo++ %>
</td>


<td>

<%= x.type === 'SITE'
    ? '🟡 SITE'
    : '🔵 CLIENT'
%>

</td>


<td>

<%= new Date(x.timestamp)
.toLocaleString('en-IN') %>

</td>


<td>
    <%= x.latitude %>
</td>


<td>
    <%= x.longitude %>
</td>


<td>
    <%= x.accuracy %>
</td>


</tr>


<%

})

}



if(attendance.logoutLocations){

attendance.logoutLocations.forEach(function(x){

%>


<tr class="logout">


<td>
    #<%= rowNo++ %>
</td>


<td>
    🔴 LOGOUT
</td>


<td>
    <%= x.time || '' %>
</td>


<td>
    <%= x.latitude || '' %>
</td>


<td>
    <%= x.longitude || '' %>
</td>


<td>
    <%= x.accuracy || '' %>
</td>


</tr>


<%

})

}

%>


</table>


</div>


</div>



<!-- ================================
     PRODUCTIVITY
================================ -->


<div class="section">


<h2>
    📊 Productivity
</h2>


<div class="metric-box">


<table class="metric-table">


<tr>

<td>
    🏢 Site Visits
</td>

<td>
    <%= siteVisitCount %>
</td>

</tr>


<tr>

<td>
    🤝 Client Meetings
</td>

<td>
    <%= clientVisitCount %>
</td>

</tr>


<tr>

<td>
    📍 Total GPS Visits
</td>

<td>
    <%= siteVisitCount + clientVisitCount %>
</td>

</tr>


<tr>

<td>
    ⚙️ Total Activities
</td>

<td>

<%= attendance.activityLog
? attendance.activityLog.length
: 0 %>

</td>

</tr>


</table>


</div>


</div>



<!-- ================================
     ROUTE QUALITY CALCULATION
================================ -->


<%

let totalAccuracy = 0

let accuracyCount = 0

let bestAccuracy = null

let worstAccuracy = null


if(locationLogs){

locationLogs.forEach(function(x){

if(x.accuracy){

totalAccuracy += x.accuracy

accuracyCount++


if(
bestAccuracy === null ||
x.accuracy < bestAccuracy
){

bestAccuracy = x.accuracy

}


if(
worstAccuracy === null ||
x.accuracy > worstAccuracy
){

worstAccuracy = x.accuracy

}


}

})

}


const avgAccuracy =

accuracyCount

? Math.round(
totalAccuracy /
accuracyCount
)

: 0

%>



<!-- ================================
     ROUTE QUALITY
================================ -->


<div class="section">


<h2>
    📡 Route Quality
</h2>


<div class="metric-box">


<table class="metric-table">


<tr>

<td>
    📡 Average GPS Accuracy
</td>

<td>
    <%= avgAccuracy %> m
</td>

</tr>


<tr>

<td>
    🎯 Best GPS Accuracy
</td>

<td>
    <%= bestAccuracy || '-' %> m
</td>

</tr>


<tr>

<td>
    📍 Worst GPS Accuracy
</td>

<td>
    <%= worstAccuracy || '-' %> m
</td>

</tr>


<tr>

<td>
    🏢 Office Configured
</td>

<td>
    <%= office ? 'YES' : 'NO' %>
</td>

</tr>


</table>


</div>


</div>


</div>



<!-- ================================
     LEAFLET MAP
================================ -->


<script>


const map = L.map(
    'routeMap'
).setView(
    [18.523243,73.760289],
    15
)


L.tileLayer(
    'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
    {
        maxZoom:19
    }
).addTo(map)


const points = []



/* ================================
   OFFICE
================================ */


<% if(office){ %>


const officeMarker =

L.marker(
[
    <%= office.latitude %>,
    <%= office.longitude %>
]
)
.addTo(map)


officeMarker.bindPopup(
    '🏢 OFFICE<br><%= office.officeName %>'
)


points.push([
    <%= office.latitude %>,
    <%= office.longitude %>
])


<% } %>



<%

let seq = 1

%>



/* ================================
   LOGIN
================================ */


<% if(attendance.loginLocations){ %>


<% attendance.loginLocations.forEach(function(x){ %>


<% if(x.latitude && x.longitude){ %>


L.marker(
[
    <%= x.latitude %>,
    <%= x.longitude %>
]
)
.addTo(map)
.bindPopup(
    '🟢 #<%= seq++ %> LOGIN<br><%= x.time || "" %>'
)


points.push([
    <%= x.latitude %>,
    <%= x.longitude %>
])


<% } %>


<% }) %>


<% } %>



/* ================================
   CLIENT / SITE LOCATIONS
================================ */


<% if(locationLogs){ %>


<% locationLogs.forEach(function(x){ %>


L.marker(
[
    <%= x.latitude %>,
    <%= x.longitude %>
]
)
.addTo(map)
.bindPopup(

'<%= x.type === "SITE"
    ? "🟡"
    : "🔵"
%> #<%= seq++ %> <%= x.type %><br>' +

'<%= new Date(x.timestamp)
.toLocaleString("en-IN") %>'

)


points.push([
    <%= x.latitude %>,
    <%= x.longitude %>
])


<% }) %>


<% } %>



/* ================================
   LOGOUT
================================ */


<% if(attendance.logoutLocations){ %>


<% attendance.logoutLocations.forEach(function(x){ %>


<% if(x.latitude && x.longitude){ %>


L.marker(
[
    <%= x.latitude %>,
    <%= x.longitude %>
]
)
.addTo(map)
.bindPopup(
    '🔴 #<%= seq++ %> LOGOUT<br><%= x.time || "" %>'
)


points.push([
    <%= x.latitude %>,
    <%= x.longitude %>
])


<% } %>


<% }) %>


<% } %>



/* ================================
   ROUTE LINE
================================ */


if(points.length){


const routeLine =

L.polyline(
    points,
    {
        weight:4
    }
)
.addTo(map)


map.fitBounds(
    routeLine.getBounds(),
    {
        padding:[40,40]
    }
)


}


</script>


</body>

</html>