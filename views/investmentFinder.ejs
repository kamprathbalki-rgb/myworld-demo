<!DOCTYPE html>
<html>

<head>

<title>Investment Opportunities</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#f4f6f9;
}

.high{
background:#2ecc71;
color:white;
}

.medium{
background:#f1c40f;
}

.low{
background:#e74c3c;
color:white;
}

</style>

</head>

<body>

<div class="container">

<h2 class="my-4">Investment Opportunity Finder</h2>

<table class="table table-bordered">

<tr>
<th>City</th>
<th>Buyer Demand</th>
<th>Visits</th>
<th>Deals</th>
<th>Opportunity Score</th>
</tr>

<% locations.forEach(function(l){ %>

<tr class="<%= l.score>8?'high':l.score>4?'medium':'low' %>">

<td><%= l.city %></td>
<td><%= l.demand %></td>
<td><%= l.visits %></td>
<td><%= l.deals %></td>
<td><%= l.score %></td>

</tr>

<% }) %>

</table>

</div>

</body>

</html>