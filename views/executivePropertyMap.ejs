<!DOCTYPE html>
<html>
<head>

<title>Property Map</title>

<meta name="viewport"
content="width=device-width, initial-scale=1.0">

<link
rel="stylesheet"
href="https://unpkg.com/leaflet/dist/leaflet.css"/>

<style>

body{
margin:0;
font-family:Arial,sans-serif;
}

#map{
height:100vh;
width:100%;
}

.top-nav{
position:absolute;
top:10px;
left:10px;
z-index:1000;
display:flex;
gap:10px;
}

.top-nav a{
background:#1f4e79;
color:white;
padding:10px 15px;
text-decoration:none;
border-radius:8px;
}

</style>

</head>

<body>

<div class="top-nav">

<a href="/executive/dashboard">
Dashboard
</a>

<a href="/executive/properties">
Properties
</a>

</div>

<div id="map"></div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>

const properties =
<%- JSON.stringify(properties) %>

const map =
L.map('map')
.setView([18.5204,73.8567],11)

L.tileLayer(
'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png'
).addTo(map)

properties.forEach(p => {

if(
p.location &&
p.location.coordinates
){

L.marker([
p.location.coordinates[1],
p.location.coordinates[0]
])
.addTo(map)
.bindPopup(
'<b>' +
(p.projectName || 'Property') +
'</b><br>' +
(p.propertyLocation || '')
)

}

})

</script>

</body>
</html>