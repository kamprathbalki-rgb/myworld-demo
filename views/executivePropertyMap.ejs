<!DOCTYPE html>
<html>

<head>

<title>Property Map</title>

<meta
name="viewport"
content="width=device-width, initial-scale=1.0, maximum-scale=1.0"
>


<link
rel="stylesheet"
href="https://unpkg.com/leaflet/dist/leaflet.css"
/>


<style>

/* ================================
   PAGE
================================ */

*{
    box-sizing:border-box;
}

html,
body{
    margin:0;
    padding:0;

    width:100%;
    height:100%;

    font-family:Arial,sans-serif;
}


/* ================================
   MAP
================================ */

#map{
    position:absolute;

    top:0;
    left:0;

    width:100%;
    height:100%;
}


/* ================================
   TOP FLOATING HEADER
================================ */

.map-header{
    position:absolute;

    top:12px;
    left:12px;
    right:12px;

    z-index:1000;

    display:flex;
    align-items:center;
    justify-content:space-between;

    pointer-events:none;
}


/* ================================
   FLOATING BUTTONS
================================ */

.map-control-btn{
    width:46px;
    height:46px;

    border-radius:50%;

    background:#1f4e79;
    color:white;

    display:flex;
    align-items:center;
    justify-content:center;

    text-decoration:none;

    font-size:22px;

    box-shadow:
        0 2px 8px rgba(0,0,0,.30),
        0 0 0 3px white;

    pointer-events:auto;
}


/* ================================
   MAP TITLE
================================ */

.map-title{
    background:#1f4e79;
    color:white;

    padding:10px 16px;

    border-radius:20px;

    font-size:14px;
    font-weight:bold;

    box-shadow:
        0 2px 8px rgba(0,0,0,.25),
        0 0 0 2px white;

    pointer-events:none;
}


/* ================================
   PROPERTY COUNT
================================ */

.property-count{
    position:absolute;

    bottom:25px;
    left:50%;

    transform:translateX(-50%);

    z-index:1000;

    background:white;
    color:#1f4e79;

    padding:9px 15px;

    border-radius:20px;

    font-size:13px;
    font-weight:bold;

    box-shadow:0 2px 8px rgba(0,0,0,.25);

    white-space:nowrap;
}


/* ================================
   LEAFLET POPUP
================================ */

.leaflet-popup-content-wrapper{
    border-radius:12px;
}

.leaflet-popup-content{
    margin:12px 14px;
    min-width:170px;
}

.popup-project{
    font-size:15px;
    font-weight:bold;

    color:#1f4e79;

    margin-bottom:6px;
}

.popup-location{
    font-size:12px;
    color:#555;

    line-height:1.4;
}


/* ================================
   MOBILE
================================ */

@media(max-width:480px){

    .map-header{
        top:10px;
        left:10px;
        right:10px;
    }

    .map-control-btn{
        width:44px;
        height:44px;

        font-size:20px;
    }

    .map-title{
        font-size:13px;

        padding:9px 13px;
    }

}

</style>

</head>


<body>



<!-- ================================
     MAP HEADER
================================ -->


<div class="map-header">


    <!-- BACK -->


    <a
        href="javascript:history.back()"
        class="map-control-btn"
        title="Back"
    >

        ←

    </a>



    <!-- TITLE -->


    <div class="map-title">

        🗺️ Property Map

    </div>



    <!-- PROPERTIES -->


    <a
        href="/executive/properties"
        class="map-control-btn"
        title="Properties"
    >

        🏢

    </a>


</div>



<!-- ================================
     MAP
================================ -->


<div id="map"></div>



<!-- ================================
     PROPERTY COUNT
================================ -->


<div class="property-count">

    🏢
    <%= properties ? properties.length : 0 %>
    Properties

</div>



<!-- ================================
     LEAFLET
================================ -->


<script
src="https://unpkg.com/leaflet/dist/leaflet.js">
</script>



<script>


/* ================================
   PROPERTY DATA
================================ */


const properties =

<%- JSON.stringify(properties) %>



/* ================================
   INITIALIZE MAP
================================ */


const map =

L.map(
    'map',
    {
        zoomControl:true
    }
)
.setView(
    [18.5204,73.8567],
    11
)



/* ================================
   MAP TILES
================================ */


L.tileLayer(

    'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',

    {

        maxZoom:19

    }

)
.addTo(map)



/* ================================
   PROPERTY MARKERS
================================ */


const propertyMarkers = []


properties.forEach(
    function(p){


        if(
            p.location &&
            p.location.coordinates &&
            p.location.coordinates.length >= 2
        ){


            const latitude =

            p.location.coordinates[1]


            const longitude =

            p.location.coordinates[0]



            const marker =

            L.marker(
                [
                    latitude,
                    longitude
                ]
            )
            .addTo(map)



            marker.bindPopup(


                '<div class="popup-project">' +

                    '🏢 ' +

                    (
                        p.projectName ||
                        'Property'
                    ) +

                '</div>' +


                '<div class="popup-location">' +

                    '📍 ' +

                    (
                        p.propertyLocation ||
                        'Location not available'
                    ) +

                '</div>'


            )



            propertyMarkers.push(
                marker
            )


        }


    }
)



/* ================================
   AUTO FIT PROPERTY MARKERS
================================ */


if(
    propertyMarkers.length > 0
){


    const markerGroup =

    L.featureGroup(
        propertyMarkers
    )


    map.fitBounds(

        markerGroup.getBounds(),

        {

            padding:[
                60,
                60
            ]

        }

    )


}



</script>


</body>

</html>