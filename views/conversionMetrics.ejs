<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width, initial-scale=1.0"
>

<title>Conversion Metrics</title>

<style>

*{
    box-sizing:border-box;
}

body{
    margin:0;
    padding:20px;
    font-family:Arial,sans-serif;
    background:#f4f6f9;
    color:#333;
}

.container{
    max-width:1100px;
    margin:auto;
}

.page-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:15px;
    margin-bottom:20px;
    padding:18px 20px;
    background:white;
    border-radius:12px;
    box-shadow:0 2px 8px rgba(0,0,0,.08);
}

.page-header h1{
    margin:0;
    color:#1f4e79;
    font-size:25px;
}

.page-header p{
    margin:6px 0 0;
    color:#777;
    font-size:13px;
}

.header-actions{
    display:flex;
    gap:8px;
}

.header-btn{
    display:inline-block;
    padding:10px 14px;
    border-radius:7px;
    color:white;
    text-decoration:none;
    font-size:12px;
    font-weight:bold;
}

.back-btn{
    background:#6c757d;
}

.home-btn{
    background:#1f4e79;
}

.metrics-grid{
    display:grid;
    grid-template-columns:repeat(3,1fr);
    gap:16px;
}

.card{
    padding:22px 15px;
    background:white;
    border-radius:12px;
    box-shadow:0 2px 8px rgba(0,0,0,.08);
    text-align:center;
}

.title{
    color:#666;
    font-size:12px;
    font-weight:bold;
}

.value{
    margin-top:10px;
    color:#1f4e79;
    font-size:32px;
    font-weight:bold;
}

.conversion-card{
    border-top:4px solid #28a745;
}

.deal-card{
    border-top:4px solid #fd7e14;
}

@media(max-width:700px){

    body{
        padding:10px;
    }

    .page-header{
        display:block;
        padding:14px;
        margin-bottom:12px;
    }

    .page-header h1{
        font-size:20px;
    }

    .page-header p{
        font-size:11px;
    }

    .header-actions{
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:6px;
        margin-top:12px;
    }

    .header-btn{
        text-align:center;
        padding:9px 5px;
        font-size:10px;
    }

    .metrics-grid{
        grid-template-columns:repeat(2,1fr);
        gap:8px;
    }

    .card{
        padding:17px 8px;
    }

    .title{
        font-size:10px;
    }

    .value{
        font-size:25px;
    }

}

@media(max-width:380px){

    .metrics-grid{
        grid-template-columns:1fr;
    }

}

</style>

</head>


<body>

<div class="container">


<div class="page-header">

<div>

<h1>
Conversion Metrics
</h1>

<p>
Lead, site visit and deal conversion performance
</p>

</div>


<div class="header-actions">

<a
href="javascript:history.back()"
class="header-btn back-btn"
>
← Back
</a>

<a
href="/dashboard"
class="header-btn home-btn"
>
Home
</a>

</div>

</div>



<div class="metrics-grid">


<div class="card">

<div class="title">
Total Leads
</div>

<div class="value">
<%= leads %>
</div>

</div>



<div class="card">

<div class="title">
Site Visits
</div>

<div class="value">
<%= visits %>
</div>

</div>



<div class="card deal-card">

<div class="title">
Deals Closed
</div>

<div class="value">
<%= deals %>
</div>

</div>



<div class="card conversion-card">

<div class="title">
Visit Conversion %
</div>

<div class="value">
<%= visitConversion %>%
</div>

</div>



<div class="card conversion-card">

<div class="title">
Deal Conversion %
</div>

<div class="value">
<%= dealConversion %>%
</div>

</div>


</div>


</div>

</body>

</html>