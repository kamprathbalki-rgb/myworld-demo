<!DOCTYPE html>
<html>
<head>

<title>Conversion Metrics</title>

<style>

body{
font-family:Arial;
background:#f4f6f9;
}

.container{
display:flex;
gap:20px;
flex-wrap:wrap;
margin-top:20px;
}

.card{
background:white;
padding:20px;
border-radius:10px;
width:200px;
box-shadow:0 2px 5px rgba(0,0,0,0.2);
text-align:center;
}

.title{
font-size:18px;
color:#555;
}

.value{
font-size:30px;
margin-top:10px;
font-weight:bold;
}

</style>

</head>

<body>

<h1>Conversion Metrics Dashboard</h1>

<div class="container">

<div class="card">
<div class="title">Total Leads</div>
<div class="value"><%= leads %></div>
</div>

<div class="card">
<div class="title">Site Visits</div>
<div class="value"><%= visits %></div>
</div>

<div class="card">
<div class="title">Deals Closed</div>
<div class="value"><%= deals %></div>
</div>

<div class="card">
<div class="title">Visit Conversion %</div>
<div class="value"><%= visitConversion %>%</div>
</div>

<div class="card">
<div class="title">Deal Conversion %</div>
<div class="value"><%= dealConversion %>%</div>
</div>

</div>

</body>
</html>