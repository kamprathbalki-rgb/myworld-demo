<h2>₹ <%= lostValue.toLocaleString('en-IN') %></h2>
</div>

</div></details>

<h2 style="margin-top:20px;">My Leads</h2>
<div class="buyer-list">

<% buyers.forEach(function(b){ %>

<div class="buyer-card" onclick="selectBuyer(this)">

<input
type="radio"
name="selectedBuyer"
value="<%= b._id %>"
class="buyer-radio"
>

<div class="buyer-row">
<b>Name:</b>

<%= b.name || '' %>
</div>

<div class="buyer-row">
<b>Phone:</b>

<% if (unlockedBuyerId && String(unlockedBuyerId) === String(b._id)) { %>
<%= b.phone || '' %>
<% } else { %>
<%= b.phone ? b.phone.slice(0,2) + 'XXXX' + b.phone.slice(-4) : '' %>
<% } %>
</div>

<div class="buyer-row">
<b>Budget:</b>
<%= b.minBudget || '' %> - <%= b.maxBudget || '' %>
</div>

<div class="buyer-row">
<b>Type:</b>
<%= b.requiredFlatType || '' %>
</div>

<div class="buyer-row">
<b>Location:</b>
<%= b.preferredLocations?.join(', ') || '' %>
</div>

<div class="buyer-row">
<b>Status:</b>
<%= b.status || 'New Lead' %>
</div>

<input
type="hidden"
class="buyer-status"
value="<%= b.status || 'New Lead' %>"
>

<input
type="hidden"
class="buyer-notes"
value="<%= b.followUpNotes || '' %>"
>

<input
type="hidden"
class="buyer-followup"
value="<%= b.nextFollowUp
? new Date(
new Date(b.nextFollowUp).getTime()
- new Date(b.nextFollowUp).getTimezoneOffset() * 60000
).toISOString().slice(0,16)
: '' %>"
>

<input
type="hidden"
class="buyer-sitevisit"
value="<%= b.siteVisitDate
? new Date(
new Date(b.siteVisitDate).getTime()
- new Date(b.siteVisitDate).getTimezoneOffset() * 60000
).toISOString().slice(0,16)
: '' %>"
>

<div style="display:none;">
Notes=<%= b.followUpNotes %>
<br>
FollowUp=<%= b.nextFollowUp %>
</div>

<input
type="hidden"
class="buyer-phone"
value="<%= b.phone || '' %>"
>

<input
type="hidden"
class="buyer-dealvalue"
value="<%= b.dealValue || '' %>"
>

<input
type="hidden"
class="buyer-lostvalue"
value="<%= b.lostValue || '' %>"
>

</div>

<% }) %>

</div>

<div id="buyerModal" style="
display:none;
position:fixed;
top:5%;
left:50%;
transform:translateX(-50%);
background:white;
border-radius:12px;
padding:15px;
width:90%;
max-width:380px;
max-height:85vh;
overflow-y:auto;
box-shadow:0 4px 20px rgba(0,0,0,.25);
z-index:9999;
">

<h3>Lead Actions</h3>

<form
id="buyerActionForm"
method="POST"
>

<input type="hidden" id="selectedBuyerId">

<button type="submit">
Save
</button>

<div>
<b>Phone:</b>
<span id="buyerPhone"></span>
</div>

<br>

<label>Status</label><br>

<select
id="status"
name="status"
>
<option value="New Lead">New Lead</option>
<option value="Contacted">Contacted</option>
<option value="Site Visit">Site Visit</option>
<option value="Negotiation">Negotiation</option>
<option value="Deal Closed">Deal Closed</option>
<option value="Lost">Lost</option>
</select>

<br><br>

<label>Deal / Lost Value</label><br>

<input
type="number"
id="dealValue"
name="dealValue"
>

<br><br>

<label>Next Follow Up</label><br>

<input
type="datetime-local"
id="nextFollowUp"
name="nextFollowUp"
>

<br><br>

<label>Site Visit Date</label><br>

<input
type="datetime-local"
id="siteVisitDate"
name="siteVisitDate"
>

<br><br>

<label>Notes</label><br>

<input
type="text"
id="followUpNotes"
name="followUpNotes"
style="width:100%;"
>

<br><br>

<a id="matchesBtn">
<button type="button">
Matches
</button>
</a>

<br><br>

<a id="editBtn">
<button type="button">
Edit Requirement
</button>
</a>

<br><br>

</form>

<button type="button" onclick="closeBuyerModal()">
Close
</button>

</div>

<br><br>

<script>

function openBuyerModal(){
document.getElementById('buyerModal').style.display='block'
}

function closeBuyerModal(){
document.getElementById('buyerModal').style.display='none'
}

document
.querySelectorAll('.buyer-radio')
.forEach(radio => {

radio.addEventListener('change', function(){

document.getElementById('selectedBuyerId').value =
this.value

document.getElementById('buyerActionForm').action =
'/executive/followup/' + this.value

const card =
this.closest('.buyer-card')

document.getElementById('buyerPhone').innerText =
card.querySelector('.buyer-phone').value

document.getElementById('status').value =
card.querySelector('.buyer-status').value

document.getElementById('followUpNotes').value =
card.querySelector('.buyer-notes').value

document.getElementById('nextFollowUp').value =
card.querySelector('.buyer-followup').value

document.getElementById('siteVisitDate').value =
card.querySelector('.buyer-sitevisit').value

const status =
card.querySelector('.buyer-status').value

if(status === 'Lost'){

document.getElementById('dealValue').value =
card.querySelector('.buyer-lostvalue').value

}else{

document.getElementById('dealValue').value =
card.querySelector('.buyer-dealvalue').value

}

document.getElementById('matchesBtn').href =
'/executive/matches/' + this.value

document.getElementById('editBtn').href =
'/executive/buyer/edit/' + this.value

openBuyerModal()

})

})

function selectBuyer(card){

    const radio =
    card.querySelector('.buyer-radio');

    radio.checked = true;

    radio.dispatchEvent(
        new Event('change')
    );

}

</script>

<script>

document.getElementById('logoutForm')
.addEventListener('submit', function(e){

    e.preventDefault()

    const form = this

    navigator.geolocation.getCurrentPosition(

        function(position){

            document.getElementById('logoutLatitude').value =
            position.coords.latitude

            document.getElementById('logoutLongitude').value =
            position.coords.longitude

            document.getElementById('logoutAccuracy').value =
            position.coords.accuracy

            HTMLFormElement.prototype.submit.call(form)

        },

        function(){

            HTMLFormElement.prototype.submit.call(form)

        }

    )

})

</script>

<script>

document
.querySelectorAll('.gpsLocationForm')
.forEach(form => {

form.addEventListener('submit', function(e){

    e.preventDefault()

    navigator.geolocation.getCurrentPosition(

        function(position){

            form.querySelector('.gpsLat').value =
            position.coords.latitude

            form.querySelector('.gpsLng').value =
            position.coords.longitude

            form.querySelector('.gpsAcc').value =
            position.coords.accuracy

            HTMLFormElement.prototype.submit.call(form)

        },

        function(){

            alert('Location not available')

        }

    )

})

})

</script>

<script>

function updateHeaderClock(){

    const now = new Date()

    document.getElementById('todayDate').innerText =
    now.toLocaleDateString(
        'en-IN',
        {
            weekday:'short',
            day:'numeric',
            month:'short',
            year:'numeric'
        }
    )

    document.getElementById('liveClock').innerText =
    now.toLocaleTimeString(
        'en-IN',
        {
            hour:'2-digit',
            minute:'2-digit',
            second:'2-digit',
            hour12:true
        }
    )

}

updateHeaderClock()

setInterval(
    updateHeaderClock,
    1000
)

</script>

