<!DOCTYPE html>
<html>

<head>

    <title>Executive Dashboard</title>

<meta
    name="viewport"
    content="width=device-width, initial-scale=1.0">


    <style>

body {
    user-select:none;
    -webkit-user-select:none;
    -ms-user-select:none;
    font-family:Arial,sans-serif;
    background:#f5f7fa;
    margin:0;
    padding:15px;
}

.summary{
    display:grid;
    grid-template-columns:
    repeat(auto-fit,minmax(180px,1fr));
    gap:15px;
    margin-top:20px;
    margin-bottom:20px;
}

.card{
    background:white;
    border:1px solid #ddd;
    border-radius:10px;
    padding:20px;
    text-align:center;
    min-height:140px;
    display:flex;
    flex-direction:column;
    justify-content:center;
    box-shadow:0 2px 8px rgba(0,0,0,.1);
}

.card h3{
margin:0;
}

.card h2{
margin:10px 0 0 0;
}

.summary a{
text-decoration:none;
color:black;
}

.attendance-card{
border:1px solid #ccc;
padding:15px;
margin-bottom:20px;
border-radius:10px;
}

.attendance-actions{
display:flex;
flex-wrap:wrap;
gap:10px;
margin-bottom:20px;
}

.attendance-actions form{
margin:0;
}

.attendance-actions button{
padding:10px 15px;
}

.duty-card{
border:1px solid #ccc;
border-radius:10px;
padding:15px;
margin-bottom:20px;
max-width:350px;
}

.duty-status{
font-size:22px;
font-weight:bold;
text-align:center;
padding:10px;
margin:10px 0;
border:1px solid #ddd;
border-radius:6px;
background:#f5f5f5;
}

.duty-row{
display:flex;
justify-content:space-between;
padding:8px 0;
border-top:1px solid #eee;
}

.buyer-list{
display:flex;
flex-direction:column;
gap:15px;
}

.buyer-card{
border:1px solid #ccc;
border-radius:10px;
padding:15px;
}

.buyer-row{
margin-bottom:8px;
}

.buyer-actions{
display:flex;
gap:10px;
flex-wrap:wrap;
margin-top:10px;
}

.top-nav{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
    margin-bottom:20px;
}

.top-nav a{
    background:#1f4e79;
    color:white;
    text-decoration:none;
    padding:10px 15px;
    border-radius:8px;
    font-weight:bold;
}

.welcome-card{
    background:white;
    padding:20px;
    border-radius:10px;
    margin-bottom:20px;
    box-shadow:0 2px 8px rgba(0,0,0,.1);
}

.attendance-grid{
    display:grid;
    grid-template-columns:
    repeat(auto-fit,minmax(220px,1fr));
    gap:15px;
    margin-bottom:20px;
}


.top-nav{
position:sticky;
top:0;
z-index:1000;
background:#f5f7fa;
padding-bottom:10px;
}

.welcome-card{
position:sticky;
top:70px;
z-index:999;
}

.quick-actions{
display:grid;
grid-template-columns:repeat(2,1fr);
gap:10px;
margin-bottom:20px;
}

.quick-card{
background:#1f4e79;
color:white;
padding:16px;
border-radius:12px;
text-align:center;
font-weight:bold;
text-decoration:none;
}

.buyer-card{
cursor:pointer;
transition:.2s;
}

.buyer-card:active{
transform:scale(.98);
}

.buyer-radio{
    display:none;
}

#buyerModal{
left:0 !important;
right:0 !important;
bottom:0 !important;
top:auto !important;
transform:none !important;
width:100% !important;
max-width:none !important;
max-height:90vh !important;
border-radius:20px 20px 0 0 !important;
}

@media(max-width:768px){
body{
padding:10px;
padding-bottom:90px;
}

.summary{
grid-template-columns:repeat(2,1fr);
}

.card{
min-height:110px;
padding:12px;
}

.attendance-grid{
grid-template-columns:1fr;
}
}


.mobile-bottom-nav{
position:fixed;
bottom:0;
left:0;
right:0;
background:#fff;
display:flex;
justify-content:space-around;
padding:12px 5px;
box-shadow:0 -2px 12px rgba(0,0,0,.15);
z-index:2000;
}

.mobile-bottom-nav a{
text-decoration:none;
font-weight:bold;
color:#1f4e79;
font-size:12px;
text-align:center;
}

.fab{
position:fixed;
right:20px;
bottom:75px;
width:60px;
height:60px;
border-radius:50%;
background:#1f4e79;
color:#fff;
display:flex;
align-items:center;
justify-content:center;
font-size:32px;
text-decoration:none;
z-index:2001;
}

.top-info-bar{
position:sticky;
top:55px;
z-index:999;
background:#fff;
display:flex;
justify-content:space-around;
padding:10px 5px;
margin-bottom:15px;
border-radius:10px;
box-shadow:0 2px 8px rgba(0,0,0,.1);
}

.top-info-item{
text-align:center;
font-size:12px;
font-weight:bold;
color:#1f4e79;
}

</style>

</head>

