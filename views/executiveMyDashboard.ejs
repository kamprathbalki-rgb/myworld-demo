<!DOCTYPE html>
<html>

<head>

    <title>Executive Dashboard</title>

<meta
    name="viewport"
    content="width=device-width, initial-scale=1.0">


    <style>

body {
    user-select:none;
    -webkit-user-select:none;
    -ms-user-select:none;
    font-family:Arial,sans-serif;
    background:#f5f7fa;
    margin:0;
    padding:15px;
}

.summary{
    display:grid;
    grid-template-columns:
    repeat(auto-fit,minmax(180px,1fr));
    gap:15px;
    margin-top:20px;
    margin-bottom:20px;
}

.card{
    background:white;
    border:1px solid #ddd;
    border-radius:10px;
    padding:20px;
    text-align:center;
    min-height:140px;
    display:flex;
    flex-direction:column;
    justify-content:center;
    box-shadow:0 2px 8px rgba(0,0,0,.1);
}

.card h3{
margin:0;
}

.card h2{
margin:10px 0 0 0;
}

.summary a{
text-decoration:none;
color:black;
}

.attendance-card{
border:1px solid #ccc;
padding:15px;
margin-bottom:20px;
border-radius:10px;
}

.attendance-actions{
display:flex;
flex-wrap:wrap;
gap:10px;
margin-bottom:20px;
}

.attendance-actions form{
margin:0;
}

.attendance-actions button{
padding:10px 15px;
}

.duty-card{
border:1px solid #ccc;
border-radius:10px;
padding:15px;
margin-bottom:20px;
max-width:350px;
}

.duty-status{
font-size:22px;
font-weight:bold;
text-align:center;
padding:10px;
margin:10px 0;
border:1px solid #ddd;
border-radius:6px;
background:#f5f5f5;
}

.duty-row{
display:flex;
justify-content:space-between;
padding:8px 0;
border-top:1px solid #eee;
}

.buyer-list{
display:flex;
flex-direction:column;
gap:15px;
}

.buyer-card{
border:1px solid #ccc;
border-radius:10px;
padding:15px;
}

.buyer-row{
margin-bottom:8px;
}

.buyer-actions{
display:flex;
gap:10px;
flex-wrap:wrap;
margin-top:10px;
}

.top-nav{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
    margin-bottom:20px;
}

.top-nav a{
    background:#1f4e79;
    color:white;
    text-decoration:none;
    padding:10px 15px;
    border-radius:8px;
    font-weight:bold;
}

.welcome-card{
    background:white;
    padding:20px;
    border-radius:10px;
    margin-bottom:20px;
    box-shadow:0 2px 8px rgba(0,0,0,.1);
}

.attendance-grid{
    display:grid;
    grid-template-columns:
    repeat(auto-fit,minmax(220px,1fr));
    gap:15px;
    margin-bottom:20px;
}

</style>

</head>

<body>

<div class="top-nav">

<a href="javascript:history.back()">Back</a>

<a href="/executive/dashboard">Home</a>

<a href="/executive/reports">Reports</a>

<a href="/executive/logout">Logout</a>

</div>

<div class="welcome-card">

<h1 style="margin-top:0;">
Executive Dashboard
</h1>

<h2>
Welcome, <%= executiveName %>
</h2>

<p style="color:#666;">
Manage Leads, Follow Ups, Site Visits and Attendance
</p>

</div>

<div class="attendance-card">

<div class="attendance-grid">

<div class="duty-card">

<h3>Today's Duty Status</h3>

<div class="duty-status">
    <%= currentStatus %>
</div>

<div class="duty-row">
    <span>Login</span>
    <strong><%= attendance?.loginTimes?.slice(-1)[0] || '--:--' %></strong>
</div>

<div class="duty-row">
    <span>Logout</span>
    <strong><%= displayLogoutTime || '--:--' %></strong>
</div>

</div>

<div class="card">

<h3>TEA</h3>

<h2><%= teaOutCount %></h2>

<p>
<%= teaActive ? 'TEA BREAK' : 'AVAILABLE' %>
</p>

<form method="POST" action="/executive/attendance/punch" style="display:inline;">
<input type="hidden" name="type" value="teaOut">
<button <%= teaActive || currentlyBusy ? 'disabled' : '' %>>
OUT
</button>
</form>

<form method="POST" action="/executive/attendance/punch" style="display:inline;">
<input type="hidden" name="type" value="teaIn">
<button <%= !teaActive ? 'disabled' : '' %>>
IN
</button>
</form>

</div>

<div class="card">

<h3>LUNCH</h3>

<h2><%= lunchOutCount %></h2>

<p>
<% if (lunchCompleted) { %>
COMPLETED
<% } else if (lunchActive) { %>
LUNCH BREAK
<% } else { %>
AVAILABLE
<% } %>
</p>

<form method="POST" action="/executive/attendance/punch" style="display:inline;">
<input type="hidden" name="type" value="lunchOut">
<button <%= lunchCompleted || lunchActive || currentlyBusy ? 'disabled' : '' %>>
OUT
</button>
</form>

<form method="POST" action="/executive/attendance/punch" style="display:inline;">
<input type="hidden" name="type" value="lunchIn">
<button <%= lunchCompleted || !lunchActive ? 'disabled' : '' %>>
IN
</button>
</form>

</div>

<div class="card">

<h3>MEETING</h3>

<h2><%= meetingOutCount %></h2>

<p>
<%= meetingActive ? 'IN MEETING' : 'AVAILABLE' %>
</p>

<form method="POST" action="/executive/attendance/punch" style="display:inline;">
<input type="hidden" name="type" value="meetingOut">
<button <%= meetingActive || currentlyBusy ? 'disabled' : '' %>>
OUT
</button>
</form>

<form method="POST" action="/executive/attendance/punch" style="display:inline;">
<input type="hidden" name="type" value="meetingIn">
<button <%= !meetingActive ? 'disabled' : '' %>>
IN
</button>
</form>

</div>

<div class="card">

<h3>SITE</h3>

<h2><%= siteOutCount %></h2>

<p>
<%= siteActive ? 'AT SITE' : 'AVAILABLE' %>
</p>

<form method="POST" action="/executive/attendance/punch" style="display:inline;">
<input type="hidden" name="type" value="siteVisitOut">
<button <%= siteActive || currentlyBusy ? 'disabled' : '' %>>
OUT
</button>
</form>

<form method="POST" action="/executive/attendance/punch" style="display:inline;">
<input type="hidden" name="type" value="siteVisitIn">
<button <%= !siteActive ? 'disabled' : '' %>>
IN
</button>
</form>

</div>

</div>

<div class="summary">

<a href="/executive/dashboard">
<div class="card">
<h3>My Leads</h3>
<h2><%= myLeads %></h2>
</div>
</a>

<a href="/executive/followups">
<div class="card">
<h3>Today's Follow Ups</h3>
<h2><%= followUps %></h2>
</div>
</a>

<a href="/executive/properties">
<div class="card">
<h3>My Properties</h3>
<h2><%= myProperties %></h2>
</div>
</a>

<a href="/executive/property-map">
<div class="card">
<h3>Property Map</h3>
<h2>View</h2>
</div>
</a>

<a href="/executive/sitevisits">
<div class="card">
<h3>Today's Visits</h3>
<h2><%= siteVisits %></h2>
</div>
</a>

<div class="card">
<h3>Contacted</h3>
<h2><%= contacted %></h2>
</div>

<div class="card">
<h3>Negotiation</h3>
<h2><%= negotiation %></h2>
</div>

<div class="card">
<h3>Pipeline (<%= openLeadCount %>)</h3>
<h2>₹ <%= pipelineValue.toLocaleString('en-IN') %></h2>
</div>

<div class="card">
<h3>Closed Value (<%= closedDeals %>)</h3>
<h2>₹ <%= closedValue.toLocaleString('en-IN') %></h2>
</div>

<div class="card">
<h3>Lost Value (<%= lost %>)</h3>
<h2>₹ <%= lostValue.toLocaleString('en-IN') %></h2>
</div>

</div>

<div class="buyer-list">

<% buyers.forEach(function(b){ %>

<div class="buyer-card">

<input
type="radio"
name="selectedBuyer"
value="<%= b._id %>"
class="buyer-radio"
>

<div class="buyer-row">
<b>Name:</b>

<%= b.name || '' %>
</div>

<div class="buyer-row">
<b>Phone:</b>

<% if (unlockedBuyerId && String(unlockedBuyerId) === String(b._id)) { %>
<%= b.phone || '' %>
<% } else { %>
<%= b.phone ? b.phone.slice(0,2) + 'XXXX' + b.phone.slice(-4) : '' %>
<% } %>
</div>

<div class="buyer-row">
<b>Budget:</b>
<%= b.minBudget || '' %> - <%= b.maxBudget || '' %>
</div>

<div class="buyer-row">
<b>Type:</b>
<%= b.requiredFlatType || '' %>
</div>

<div class="buyer-row">
<b>Location:</b>
<%= b.preferredLocations?.join(', ') || '' %>
</div>

<div class="buyer-row">
<b>Status:</b>
<%= b.status || 'New Lead' %>
</div>

<input
type="hidden"
class="buyer-status"
value="<%= b.status || 'New Lead' %>"
>

<input
type="hidden"
class="buyer-notes"
value="<%= b.followUpNotes || '' %>"
>

<input
type="hidden"
class="buyer-followup"
value="<%= b.nextFollowUp
? new Date(
new Date(b.nextFollowUp).getTime()
- new Date(b.nextFollowUp).getTimezoneOffset() * 60000
).toISOString().slice(0,16)
: '' %>"
>

<input
type="hidden"
class="buyer-sitevisit"
value="<%= b.siteVisitDate
? new Date(
new Date(b.siteVisitDate).getTime()
- new Date(b.siteVisitDate).getTimezoneOffset() * 60000
).toISOString().slice(0,16)
: '' %>"
>

<div style="display:none;">
Notes=<%= b.followUpNotes %>
<br>
FollowUp=<%= b.nextFollowUp %>
</div>

<input
type="hidden"
class="buyer-phone"
value="<%= b.phone || '' %>"
>

<input
type="hidden"
class="buyer-dealvalue"
value="<%= b.dealValue || '' %>"
>

<input
type="hidden"
class="buyer-lostvalue"
value="<%= b.lostValue || '' %>"
>

</div>

<% }) %>

</div>

<div id="buyerModal" style="
display:none;
position:fixed;
top:5%;
left:50%;
transform:translateX(-50%);
background:white;
border-radius:12px;
padding:15px;
width:90%;
max-width:380px;
max-height:85vh;
overflow-y:auto;
box-shadow:0 4px 20px rgba(0,0,0,.25);
z-index:9999;
">

<h3>Lead Actions</h3>

<form
id="buyerActionForm"
method="POST"
>

<input type="hidden" id="selectedBuyerId">

<button type="submit">
Save
</button>

<div>
<b>Phone:</b>
<span id="buyerPhone"></span>
</div>

<br>

<label>Status</label><br>

<select
id="status"
name="status"
>
<option value="New Lead">New Lead</option>
<option value="Contacted">Contacted</option>
<option value="Site Visit">Site Visit</option>
<option value="Negotiation">Negotiation</option>
<option value="Deal Closed">Deal Closed</option>
<option value="Lost">Lost</option>
</select>

<br><br>

<label>Deal / Lost Value</label><br>

<input
type="number"
id="dealValue"
name="dealValue"
>

<br><br>

<label>Next Follow Up</label><br>

<input
type="datetime-local"
id="nextFollowUp"
name="nextFollowUp"
>

<br><br>

<label>Site Visit Date</label><br>

<input
type="datetime-local"
id="siteVisitDate"
name="siteVisitDate"
>

<br><br>

<label>Notes</label><br>

<input
type="text"
id="followUpNotes"
name="followUpNotes"
style="width:100%;"
>

<br><br>

<a id="matchesBtn">
<button type="button">
Matches
</button>
</a>

<br><br>

<a id="editBtn">
<button type="button">
Edit Requirement
</button>
</a>

<br><br>

</form>

<button type="button" onclick="closeBuyerModal()">
Close
</button>

</div>

<br><br>

<script>

function openBuyerModal(){
document.getElementById('buyerModal').style.display='block'
}

function closeBuyerModal(){
document.getElementById('buyerModal').style.display='none'
}

document
.querySelectorAll('.buyer-radio')
.forEach(radio => {

radio.addEventListener('change', function(){

document.getElementById('selectedBuyerId').value =
this.value

document.getElementById('buyerActionForm').action =
'/executive/followup/' + this.value

const card =
this.closest('.buyer-card')

document.getElementById('buyerPhone').innerText =
card.querySelector('.buyer-phone').value

document.getElementById('status').value =
card.querySelector('.buyer-status').value

document.getElementById('followUpNotes').value =
card.querySelector('.buyer-notes').value

document.getElementById('nextFollowUp').value =
card.querySelector('.buyer-followup').value

document.getElementById('siteVisitDate').value =
card.querySelector('.buyer-sitevisit').value

const status =
card.querySelector('.buyer-status').value

if(status === 'Lost'){

document.getElementById('dealValue').value =
card.querySelector('.buyer-lostvalue').value

}else{

document.getElementById('dealValue').value =
card.querySelector('.buyer-dealvalue').value

}

document.getElementById('matchesBtn').href =
'/executive/matches/' + this.value

document.getElementById('editBtn').href =
'/executive/buyer/edit/' + this.value

openBuyerModal()

})

})

</script>

</body>

</html>