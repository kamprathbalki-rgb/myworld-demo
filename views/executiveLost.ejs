<!DOCTYPE html>
<html>

<head>
<title>Lost Leads</title>

<style>

table{
width:100%;
border-collapse:collapse;
}

th,td{
border:1px solid #ccc;
padding:10px;
text-align:left;
}

th{
background:#f5f5f5;
}

</style>

</head>

<body>

<a href="/executive/dashboard">Dashboard</a>

<hr>

<h1>Lost Leads</h1>

<table>

<tr>
<th>Buyer</th>
<th>Phone</th>
<th>Budget</th>
<th>Property Type</th>
<th>Preferred Location</th>
<th>Status</th>
</tr>

<% buyers.forEach(function(b){ %>

<tr>

<td>
<%= b.name || '' %>
</td>

<td>
<%= b.phone
? b.phone.slice(0,2) + 'XXXX' + b.phone.slice(-4)
: '' %>
</td>

<td>
<%= b.minBudget || '' %> - <%= b.maxBudget || '' %>
</td>

<td>
<%= b.requiredFlatType || '' %>
</td>

<td>
<%= b.preferredLocations && b.preferredLocations.length
? b.preferredLocations.join(', ')
: '' %>
</td>

<td>
<%= b.status || '' %>
</td>

</tr>

<% }) %>

</table>

</body>

</html>