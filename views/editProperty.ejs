<script>


function showTab(
tabId
){


document
.getElementById(
'apartmentTab'
)
.style
.display =
'none';


document
.getElementById(
'otherTab'
)
.style
.display =
'none';


document
.getElementById(
'apartmentTabButton'
)
.classList
.remove(
'active'
);


document
.getElementById(
'otherTabButton'
)
.classList
.remove(
'active'
);


document
.getElementById(
tabId
)
.style
.display =
'block';


if(
tabId ===
'apartmentTab'
){

document
.getElementById(
'apartmentTabButton'
)
.classList
.add(
'active'
);

}else{

document
.getElementById(
'otherTabButton'
)
.classList
.add(
'active'
);

}


}


