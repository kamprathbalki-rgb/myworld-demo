<!DOCTYPE html>
<html>

<head>

<title>Real Estate Intelligence</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#f4f6f9;
}

.card{
padding:20px;
background:white;
border-radius:10px;
box-shadow:0 2px 6px rgba(0,0,0,0.1);
}

</style>

</head>

<body>

<div class="container">

<h2 class="my-4">Real Estate Intelligence Dashboard</h2>

<div class="row g-4">

<div class="col-md-6">
<div class="card">
<canvas id="bedroomChart"></canvas>
</div>
</div>

<div class="col-md-6">
<div class="card">
<canvas id="budgetChart"></canvas>
</div>
</div>

<div class="col-md-6">
<div class="card">
<canvas id="propertyChart"></canvas>
</div>
</div>

</div>

</div>

<script>

const bedroomLabels = <%- JSON.stringify(bedroomDemand.map(b=>b._id)) %>
const bedroomData = <%- JSON.stringify(bedroomDemand.map(b=>b.count)) %>

new Chart(document.getElementById('bedroomChart'),{

type:'bar',

data:{
labels:bedroomLabels,
datasets:[{
label:'Bedroom Demand',
data:bedroomData
}]
}

})


const budgetLabels = <%- JSON.stringify(budgetDemand.map(b=>b._id)) %>
const budgetData = <%- JSON.stringify(budgetDemand.map(b=>b.count)) %>

new Chart(document.getElementById('budgetChart'),{

type:'pie',

data:{
labels:budgetLabels,
datasets:[{
label:'Budget Demand',
data:budgetData
}]
}

})


const propertyLabels = <%- JSON.stringify(topProperties.map(p=>p._id)) %>
const propertyData = <%- JSON.stringify(topProperties.map(p=>p.visits)) %>

new Chart(document.getElementById('propertyChart'),{

type:'bar',

data:{
labels:propertyLabels,
datasets:[{
label:'Top Properties by Visits',
data:propertyData
}]
}

})

</script>

</body>

</html>