<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width, initial-scale=1.0"
>

<title>Add Property</title>

<style>

*{
    box-sizing:border-box;
}

body{
    margin:0;
    padding:20px;
    font-family:Arial,sans-serif;
    background:#f5f7fa;
    color:#333;
}

.container{
    max-width:1100px;
    margin:auto;
}


/* ================================
   HEADER
================================ */

.page-header{
    display:flex;
    justify-content:space-between;
    align-items:center;
    gap:15px;

    margin-bottom:20px;
    padding:18px 20px;

    background:white;

    border-radius:12px;

    box-shadow:
    0 2px 8px rgba(0,0,0,.08);
}

.header-info h1{
    margin:0;
    color:#1f4e79;
    font-size:25px;
}

.header-info p{
    margin:6px 0 0;
    color:#777;
    font-size:13px;
}

.header-actions{
    display:flex;
    gap:8px;
}

.header-btn{
    display:inline-block;

    padding:10px 14px;

    border-radius:7px;

    color:white;

    text-decoration:none;

    font-size:12px;

    font-weight:bold;
}

.back-btn{
    background:#6c757d;
}

.home-btn{
    background:#1f4e79;
}


/* ================================
   SECTIONS
================================ */

.form-section{
    margin-bottom:18px;

    padding:20px;

    background:white;

    border-radius:12px;

    box-shadow:
    0 2px 8px rgba(0,0,0,.08);
}

.section-title{
    margin:0 0 18px;

    padding-bottom:10px;

    border-bottom:1px solid #eee;

    color:#1f4e79;

    font-size:18px;
}

.section-note{
    margin:-5px 0 18px;

    color:#777;

    font-size:12px;
}


/* ================================
   PROPERTY MODE
================================ */

.mode-grid{
    display:grid;

    grid-template-columns:
    repeat(2,1fr);

    gap:10px;
}

.mode-option{
    position:relative;

    display:block;

    cursor:pointer;
}

.mode-option input{
    position:absolute;

    opacity:0;

    pointer-events:none;
}

.mode-card{
    display:block;

    padding:16px;

    border:2px solid #ddd;

    border-radius:9px;

    text-align:center;

    color:#555;

    font-size:13px;

    font-weight:bold;

    transition:.2s;
}

.mode-option input:checked + .mode-card{
    border-color:#1f4e79;

    background:#eef5fb;

    color:#1f4e79;
}


/* ================================
   FORM
================================ */

.form-grid{
    display:grid;

    grid-template-columns:
    repeat(2,1fr);

    gap:16px 20px;
}

.form-group{
    display:flex;

    flex-direction:column;

    gap:6px;
}

.form-group.full-width{
    grid-column:1 / -1;
}

.form-group > label{
    color:#555;

    font-size:12px;

    font-weight:bold;
}

.form-control{
    width:100%;

    min-height:42px;

    padding:9px 10px;

    border:1px solid #ccc;

    border-radius:6px;

    background:white;

    color:#333;

    font-family:Arial,sans-serif;

    font-size:13px;
}

.form-control:focus{
    outline:none;

    border-color:#1f4e79;
}

textarea.form-control{
    min-height:100px;

    resize:vertical;
}


/* ================================
   CHECKBOXES
================================ */

.checkbox-grid{
    display:flex;

    flex-wrap:wrap;

    gap:9px;
}

.checkbox-item{
    display:flex;

    align-items:center;

    gap:7px;

    padding:9px 12px;

    background:#f8fafc;

    border:1px solid #ddd;

    border-radius:7px;

    color:#555;

    font-size:12px;
}


/* ================================
   CONFIGURATION TABS
================================ */

.tab-buttons{
    display:grid;

    grid-template-columns:
    1fr 1fr;

    gap:8px;

    margin-bottom:18px;
}

.tab-btn{
    min-height:44px;

    padding:10px;

    border:1px solid #1f4e79;

    border-radius:7px;

    background:white;

    color:#1f4e79;

    cursor:pointer;

    font-size:12px;

    font-weight:bold;
}

.tab-btn.active{
    background:#1f4e79;

    color:white;
}


/* ================================
   TABLE
================================ */

.table-wrapper{
    width:100%;

    overflow-x:auto;

    border:1px solid #eee;

    border-radius:9px;
}

.configuration-table{
    width:100%;

    min-width:750px;

    border-collapse:collapse;
}

.configuration-table th{
    padding:11px 9px;

    background:#1f4e79;

    color:white;

    text-align:left;

    font-size:10px;

    text-transform:uppercase;
}

.configuration-table td{
    padding:8px;

    border-bottom:1px solid #eee;

    font-size:12px;
}

.configuration-table input{
    width:100%;

    min-width:100px;

    padding:8px;

    border:1px solid #ccc;

    border-radius:5px;
}


/* ================================
   ACTIONS
================================ */

.form-actions{
    display:flex;

    justify-content:flex-end;

    gap:10px;
}

.cancel-btn{
    display:inline-block;

    min-width:110px;

    padding:12px 18px;

    background:#6c757d;

    color:white;

    text-align:center;

    text-decoration:none;

    border-radius:7px;

    font-size:13px;

    font-weight:bold;
}

.save-btn{
    min-width:180px;

    padding:12px 20px;

    border:none;

    border-radius:7px;

    background:#28a745;

    color:white;

    cursor:pointer;

    font-size:13px;

    font-weight:bold;
}


/* ================================
   MOBILE
================================ */

@media(max-width:700px){

    body{
        padding:10px;
    }

    .page-header{
        display:block;

        padding:14px;

        margin-bottom:12px;
    }

    .header-info h1{
        font-size:20px;
    }

    .header-info p{
        font-size:11px;
    }

    .header-actions{
        display:grid;

        grid-template-columns:
        1fr 1fr;

        gap:6px;

        margin-top:12px;
    }

    .header-btn{
        text-align:center;

        font-size:10px;
    }

    .form-section{
        padding:14px;

        margin-bottom:12px;
    }

    .form-grid{
        grid-template-columns:1fr;

        gap:13px;
    }

    .form-group.full-width{
        grid-column:auto;
    }

    .mode-grid{
        grid-template-columns:1fr;
    }

    .checkbox-grid{
        display:grid;

        grid-template-columns:
        repeat(2,1fr);
    }

    .tab-buttons{
        grid-template-columns:1fr;
    }

    .configuration-table{
        min-width:650px;
    }

    .form-actions{
        display:grid;

        grid-template-columns:
        1fr 1fr;

        gap:8px;
    }

    .cancel-btn,
    .save-btn{
        width:100%;

        min-width:0;
    }

}

</style>

</head>


<body>


<div class="container">


<!-- ================================
     HEADER
================================ -->

<div class="page-header">


<div class="header-info">

<h1>
Add Property
</h1>

<p>
Add a builder project or individual property
</p>

</div>


<div class="header-actions">


<a
href="javascript:history.back()"
class="header-btn back-btn"
>
← Back
</a>


<a
href="/dashboard"
class="header-btn home-btn"
>
Home
</a>


</div>


</div>



<form
method="POST"
action="/property/save"
>



