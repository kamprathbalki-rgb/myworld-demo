</div>



<div class="form-group">

<label>
Quoted Price
</label>

<input
type="number"
name="singleQuotedPrice"
class="form-control"
>

</div>



<div class="form-group">

<label>
Closing Price
</label>

<input
type="number"
name="singleClosingPrice"
class="form-control"
