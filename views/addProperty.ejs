<option>2 BHK</option>
<option>2.5 BHK</option>
<option>3 BHK</option>
<option>3.5 BHK</option>
<option>4 BHK</option>
<option>4.5 BHK</option>
<option>5 BHK</option>
<option>5+ BHK</option>
<option>Villa</option>
<option>Plot</option>
<option>Office</option>
<option>Showroom</option>
<option>Retail</option>
