<!DOCTYPE html>
<html>
<head>
    <title>Property Media</title>
    <style>
        body{
            font-family:Arial,sans-serif;
            margin:40px;
            max-width:900px;
        }

        .card{
            border:1px solid #ddd;
            border-radius:8px;
            padding:20px;
            margin-bottom:20px;
        }

        h2{
            margin-top:0;
        }

        input[type=file]{
            width:100%;
            margin:10px 0;
        }

        button{
            padding:10px 20px;
            background:#007bff;
            color:white;
            border:none;
            border-radius:5px;
            cursor:pointer;
        }
    </style>
</head>

<body>

<h1><%= property.projectName %></h1>

<form method="POST"
      action="/property-media/<%= property._id %>/upload"
      enctype="multipart/form-data">

<div class="card">

<h2>Cover Photo</h2>

<input
    type="file"
    name="coverPhoto"
    accept="image/*">

</div>

<div class="card">

<h2>Configuration Photos</h2>

<%
const configurationKeys = property.configurations.map(c => c.flatType);
configurationKeys.forEach(function(configuration){
%>

<h3><%= configuration %></h3>

<%
const placeholders = mediaLimits.configurationPhotos[configuration];

placeholders.forEach(function(photo){
%>

<label><%= photo %></label>

<input
    type="file"
    name="configuration_<%= configuration %>_<%= photo %>"
    accept="image/*">

<%
});
});
%>

</div>

<button type="submit">
    Save Property Media
</button>

</form>

</body>
</html>