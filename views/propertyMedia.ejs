<!DOCTYPE html>
<html>
<head>

    <title>Property Media</title>

    <style>

body{
    font-family:Arial,sans-serif;
    background:#f5f5f5;
    margin:30px;
    max-width:1200px;
    margin:auto;
    padding:20px;
}

.card{
    background:#fff;
    padding:20px;
    margin-bottom:25px;
    border-radius:10px;
    box-shadow:0 2px 8px rgba(0,0,0,.08);
    border:1px solid #e5e5e5;
}

h2{
    margin-top:0;
    color:#333;
    border-left:4px solid #007bff;
    padding-left:10px;
}

table{
    width:100%;
    border-collapse:collapse;
    margin-bottom:20px;
    background:#fff;
    border-radius:6px;
    overflow:hidden;
}

        td{
            padding:8px;
            border-bottom:1px solid #eee;
        }

input[type=file]{
    width:100%;
    padding:8px;
    border:1px solid #ddd;
    border-radius:5px;
    background:#fff;
}

.btn{
    margin-top:20px;
    background:#007bff;
    color:#fff;
    border:none;
    padding:12px 25px;
    border-radius:6px;
    cursor:pointer;
    font-size:16px;
    font-weight:bold;
    transition:.2s;
}

.btn:hover{
    background:#0056b3;
}

    </style>

</head>

<body>

<div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:20px;">

    <div>

        <a href="/properties"
           style="text-decoration:none;background:#28a745;color:#fff;padding:10px 18px;border-radius:6px;font-weight:bold;">
            🏠 Home
        </a>

        <button
            type="button"
            onclick="history.back()"
            style="margin-left:10px;background:#6c757d;color:#fff;border:none;padding:10px 18px;border-radius:6px;cursor:pointer;font-weight:bold;">
            ← Back
        </button>

    </div>

</div>

<form method="POST"
      enctype="multipart/form-data"
      action="/property-media/<%= property._id %>/upload">

<div class="card">

<h1 style="margin-top:0;">
    <%= property.projectName %>
</h1>

<p style="color:#666;margin-top:-10px;">
    Manage Photos, Videos & Documents
</p>

<hr style="margin:20px 0;">

<h2>Cover Photo</h2>

<% if (media.coverPhoto && media.coverPhoto.filename) { %>

<div style="margin-bottom:15px;">

    <a href="/uploads/properties/cover/<%= media.coverPhoto.filename %>" target="_blank">

        <img
            src="/uploads/properties/cover/<%= media.coverPhoto.filename %>"
            style="max-width:250px;border:1px solid #ddd;border-radius:8px;">

</a>

<div style="margin-top:10px;">

<form
    action="/property-media/<%= property._id %>/cover/delete"
    method="POST"
    style="display:inline;">

    <button
        type="submit"
        onclick="return confirm('Delete the cover photo?')"
        style="background:#dc3545;color:#fff;border:none;padding:8px 14px;border-radius:5px;cursor:pointer;">
        🗑 Delete
    </button>

</form>

<form
    action="/property-media/<%= property._id %>/cover/replace"
    method="POST"
    enctype="multipart/form-data"
    style="display:inline;">

    <input
        type="file"
        id="coverPhotoReplace"
        name="coverPhoto"
        accept="image/*"
        style="display:none"
        onchange="this.form.submit()">

    <button
        type="button"
        onclick="document.getElementById('coverPhotoReplace').click()"
        style="background:#ffc107;color:#000;border:none;padding:8px 14px;border-radius:5px;cursor:pointer;margin-left:8px;">
        ✏ Replace
    </button>

</form>

</div>

</div>

<% } %>

<input
    type="file"
    name="coverPhoto"
    accept="image/*">

<p style="color:#666;font-size:13px;margin-top:8px;">
    Upload one cover image. Uploading a new image will replace the existing cover photo.
</p>

</div>

<div class="card">

<h2>Configuration Photos</h2>

<p style="color:#666;font-size:13px;margin-top:-10px;">
    Upload photos for each available configuration. You can select multiple images.
</p>

<%
const configurationKeys = Object.keys(mediaLimits.configurationPhotos);
%>

<% configurationKeys.forEach(function(configuration){ %>

<h3><%= configuration %></h3>

<table>

<%
const placeholders = mediaLimits.configurationPhotos[configuration];
%>

<% placeholders.forEach(function(photo){ %>

<tr>

<td width="40%"><%= photo %></td>

<td>

<%
const uploadedPhotos =
media.configurationPhotos.get(configuration) || [];
%>

<% uploadedPhotos.forEach(function(file){ %>

<div style="display:inline-block;margin:8px;text-align:center;">

    <a href="/uploads/properties/configurations/<%= file.filename %>" target="_blank">

        <img
            src="/uploads/properties/configurations/<%= file.filename %>"
            style="width:120px;height:90px;object-fit:cover;border:1px solid #ddd;border-radius:6px;display:block;">

    </a>

<form
    action="/property-media/<%= property._id %>/configuration/delete"
    method="POST"
    style="margin-top:6px;">

    <input
        type="hidden"
        name="configuration"
        value="<%= configuration %>">

    <input
        type="hidden"
        name="filename"
        value="<%= file.filename %>">

    <button
        type="submit"
        onclick="return confirm('Delete this configuration photo?')"
        style="background:#dc3545;color:#fff;border:none;padding:5px 10px;border-radius:4px;cursor:pointer;">
        🗑 Delete
    </button>

</form>

<form
    action="/property-media/<%= property._id %>/configuration/replace"
    method="POST"
    enctype="multipart/form-data"
    style="display:inline;">

    <input type="hidden" name="configuration" value="<%= configuration %>">
    <input type="hidden" name="oldFilename" value="<%= file.filename %>">

    <input
        type="file"
        name="configuration_<%= configuration %>"
        style="display:none"
        onchange="this.form.submit()"
        id="replace_<%= file.filename %>">

    <button
        type="button"
        onclick="document.getElementById('replace_<%= file.filename %>').click()"
        style="margin-top:6px;background:#ffc107;color:#000;border:none;padding:5px 10px;border-radius:4px;cursor:pointer;">
        ✏ Replace
    </button>

</form>

</div>

<% }) %>

<input
type="file"
accept="image/*"
name="configuration_<%= configuration %>"
multiple>

</td>

</tr>

<% }) %>

</table>

<br>

<% }) %>

</div>

<div class="card">

<h2>Amenity Photos (<%= mediaLimits.amenityPhotos.maxFiles %>)</h2>

<p style="color:#666;font-size:13px;margin-top:-10px;">
    Upload multiple photos for amenities.
</p>

<% if (media.amenityPhotos && media.amenityPhotos.length) { %>

<div style="margin-bottom:15px;">

<% media.amenityPhotos.forEach(function(photo){ %>

<div style="display:inline-block;margin:8px;text-align:center;">

    <a href="/uploads/properties/amenities/<%= photo.filename %>" target="_blank">

        <img
            src="/uploads/properties/amenities/<%= photo.filename %>"
            style="width:120px;height:90px;object-fit:cover;border:1px solid #ddd;border-radius:6px;display:block;">

    </a>

<form
    action="/property-media/<%= property._id %>/amenity/delete"
    method="POST"
    style="display:inline;">

    <input
        type="hidden"
        name="filename"
        value="<%= photo.filename %>">

    <button
        type="submit"
        onclick="return confirm('Delete this amenity photo?')"
        style="margin-top:6px;background:#dc3545;color:#fff;border:none;padding:5px 10px;border-radius:4px;cursor:pointer;">
        🗑 Delete
    </button>

</form>

<form
    action="/property-media/<%= property._id %>/amenity/replace"
    method="POST"
    enctype="multipart/form-data"
    style="display:inline;">

    <input
        type="hidden"
        name="oldFilename"
        value="<%= photo.filename %>">

    <input
        type="file"
        id="amenityReplace_<%= photo.filename %>"
        name="amenityPhoto"
        accept="image/*"
        style="display:none"
        onchange="this.form.submit()">

    <button
        type="button"
        onclick="document.getElementById('amenityReplace_<%= photo.filename %>').click()"
        style="margin-top:6px;background:#ffc107;color:#000;border:none;padding:5px 10px;border-radius:4px;cursor:pointer;">
        ✏ Replace
    </button>

</form>

</div>

<% }) %>

</div>

<% } %>

<% for(let i=1;i<=mediaLimits.amenityPhotos.maxFiles;i++){ %>

<p>

Amenity Photo <%= i %>

<input
type="file"
accept="image/*"
name="amenityPhotos"
multiple>

</p>

<% } %>

</div>

<div class="card">

<h2>USP Photos (<%= mediaLimits.uspPhotos.maxFiles %>)</h2>

<p style="color:#666;font-size:13px;margin-top:-10px;">
    Upload multiple USP photos.
</p>

<% if (media.uspPhotos && media.uspPhotos.length) { %>

<div style="margin-bottom:15px;">

<% media.uspPhotos.forEach(function(photo){ %>

<div style="display:inline-block;margin:8px;text-align:center;">

    <a href="/uploads/properties/usp/<%= photo.filename %>" target="_blank">

        <img
            src="/uploads/properties/usp/<%= photo.filename %>"
            style="width:120px;height:90px;object-fit:cover;border:1px solid #ddd;border-radius:6px;display:block;">

    </a>

<form
    action="/property-media/<%= property._id %>/usp/delete"
    method="POST"
    style="display:inline;">

    <input
        type="hidden"
        name="filename"
        value="<%= photo.filename %>">

    <button
        type="submit"
        onclick="return confirm('Delete this USP photo?')"
        style="margin-top:6px;background:#dc3545;color:#fff;border:none;padding:5px 10px;border-radius:4px;cursor:pointer;">
        🗑 Delete
    </button>

</form>

<form
    action="/property-media/<%= property._id %>/usp/replace"
    method="POST"
    enctype="multipart/form-data"
    style="display:inline;">

    <input
        type="hidden"
        name="oldFilename"
        value="<%= photo.filename %>">

    <input
        type="file"
        id="uspReplace_<%= photo.filename %>"
        name="uspPhoto"
        accept="image/*"
        style="display:none"
        onchange="this.form.submit()">

    <button
        type="button"
        onclick="document.getElementById('uspReplace_<%= photo.filename %>').click()"
        style="margin-top:6px;background:#ffc107;color:#000;border:none;padding:5px 10px;border-radius:4px;cursor:pointer;">
        ✏ Replace
    </button>

</form>

</div>

<% }) %>

</div>

<% } %>

<% for(let i=1;i<=mediaLimits.uspPhotos.maxFiles;i++){ %>

<p>

USP Photo <%= i %>

<input
type="file"
accept="image/*"
name="uspPhotos"
multiple>

</p>

<% } %>

</div>

<div class="card">

<h2>Property Video</h2>

<p style="color:#666;font-size:13px;margin-top:-10px;">
    Upload one property walkthrough or promotional video.
</p>

<% if (media.propertyVideo && media.propertyVideo.filename) { %>

<div style="margin-bottom:15px;">

    <video
        controls
        width="350"
        style="max-width:100%;border-radius:8px;">

        <source
            src="/uploads/properties/videos/<%= media.propertyVideo.filename %>">

    </video>

    <br><br>

    <a
        href="/uploads/properties/videos/<%= media.propertyVideo.filename %>"
        target="_blank">
        ▶ Open Video
    </a>

    <br><br>

<form
    action="/property-media/<%= property._id %>/video/delete"
    method="POST"
    style="display:inline;">

    <button
        type="submit"
        onclick="return confirm('Delete this property video?')"
        style="background:#dc3545;color:#fff;border:none;padding:8px 14px;border-radius:5px;cursor:pointer;">
        🗑 Delete
    </button>

</form>

<form
    action="/property-media/<%= property._id %>/video/replace"
    method="POST"
    enctype="multipart/form-data"
    style="display:inline;">

    <input
        type="file"
        id="videoReplace"
        name="propertyVideo"
        accept="video/*"
        style="display:none"
        onchange="this.form.submit()">

    <button
        type="button"
        onclick="document.getElementById('videoReplace').click()"
        style="background:#ffc107;color:#000;border:none;padding:8px 14px;border-radius:5px;cursor:pointer;margin-left:8px;">
        ✏ Replace
    </button>

</form>

</div>

<% } %>

<input
type="file"
accept="video/*"
name="propertyVideo">

</div>

<div class="card">

<h2>Builder Documents</h2>

<p style="color:#666;font-size:13px;margin-top:-10px;">
    Upload PDF documents like brochure, floor plans, approvals, price list, etc.
</p>

<% if (media.builderDocuments && media.builderDocuments.length) { %>

<div style="margin-bottom:15px;">

<% media.builderDocuments.forEach(function(doc){ %>

<div style="margin-bottom:12px;padding:10px;border:1px solid #ddd;border-radius:6px;">

    📄

    <a
        href="/uploads/properties/documents/<%= doc.filename %>"
        target="_blank">

        <%= doc.originalName %>

    </a>

    <br><br>

<form
    action="/property-media/<%= property._id %>/document/delete"
    method="POST"
    style="display:inline;">

    <input
        type="hidden"
        name="filename"
        value="<%= doc.filename %>">

    <button
        type="submit"
        onclick="return confirm('Delete this document?')"
        style="background:#dc3545;color:#fff;border:none;padding:6px 12px;border-radius:4px;cursor:pointer;">
        🗑 Delete
    </button>

</form>

<form
    action="/property-media/<%= property._id %>/document/replace"
    method="POST"
    enctype="multipart/form-data"
    style="display:inline;">

    <input
        type="hidden"
        name="oldFilename"
        value="<%= doc.filename %>">

    <input
        type="file"
        id="documentReplace_<%= doc.filename %>"
        name="builderDocument"
        accept=".pdf"
        style="display:none"
        onchange="this.form.submit()">

    <button
        type="button"
        onclick="document.getElementById('documentReplace_<%= doc.filename %>').click()"
        style="background:#ffc107;color:#000;border:none;padding:6px 12px;border-radius:4px;cursor:pointer;margin-left:8px;">
        ✏ Replace
    </button>

</form>

</div>

<% }) %>

</div>

<% } %>

<% for(let i=1;i<=mediaLimits.builderDocuments.maxFiles;i++){ %>

<p>

PDF <%= i %>

<input
type="file"
accept=".pdf"
name="builderDocuments"
multiple>

</p>

<% } %>

</div>

<div style="text-align:center;margin-top:30px;">

    <button class="btn" type="submit">
        💾 Save Property Media
    </button>

</div>

</form>

</body>
</html>