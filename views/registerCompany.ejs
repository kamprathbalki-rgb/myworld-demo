<!DOCTYPE html>
<html>

<head>
<title>Register Company</title>

<meta name="viewport" content="width=device-width, initial-scale=1.0">

<style>

/* ================================
   GLOBAL
================================ */

*{
    box-sizing:border-box;
}

body{
    margin:0;
    padding:20px;

    font-family:Arial,sans-serif;

    background:#f4f6f9;
    color:#222;
}


/* ================================
   PAGE TITLE
================================ */

h2{
    max-width:700px;

    margin:0 auto;

    padding:17px 20px;

    background:#1f4e79;
    color:white;

    border-radius:12px 12px 0 0;

    font-size:20px;

    box-shadow:0 2px 8px rgba(0,0,0,.12);
}


/* ================================
   FORM CARD
================================ */

form{
    max-width:700px;

    margin:0 auto;

    padding:22px;

    background:white;

    border-radius:0 0 12px 12px;

    box-shadow:0 2px 8px rgba(0,0,0,.10);
}


/* ================================
   LABELS
================================ */

label{
    color:#555;

    font-size:13px;
    font-weight:bold;
}


/* ================================
   INPUTS & SELECTS
================================ */

input,
select{
    width:100%;

    margin-top:7px;

    padding:12px;

    border:1px solid #d8dde3;
    border-radius:8px;

    background:white;

    color:#222;

    font-family:Arial,sans-serif;
    font-size:14px;

    transition:
        border-color .2s,
        box-shadow .2s;
}

input:focus,
select:focus{
    outline:none;

    border-color:#1f4e79;

    box-shadow:
        0 0 0 3px
        rgba(31,78,121,.08);
}


/* ================================
   ADMIN SECTION
================================ */

h3{
    margin-top:8px;

    padding:13px 0 10px 0;

    color:#1f4e79;

    font-size:16px;

    border-bottom:1px solid #e5e9ed;
}


/* ================================
   BUTTON
================================ */

button[type="submit"]{
    width:100%;

    padding:14px;

    border:none;
    border-radius:9px;

    background:#1f4e79;
    color:white;

    font-size:15px;
    font-weight:bold;

    cursor:pointer;

    box-shadow:0 2px 6px rgba(0,0,0,.12);
}

button[type="submit"]:hover{
    background:#173d61;
}


/* ================================
   TABLET
================================ */

@media(max-width:768px){

    body{
        padding:15px;
    }

}


/* ================================
   MOBILE
================================ */

@media(max-width:600px){

    body{
        padding:10px;
    }

    h2{
        padding:15px;

        font-size:18px;

        border-radius:10px 10px 0 0;
    }

    form{
        padding:16px;

        border-radius:0 0 10px 10px;
    }

    input,
    select{
        min-height:46px;

        padding:11px 12px;

        font-size:16px;
    }

    h3{
        font-size:15px;
    }

    button[type="submit"]{
        min-height:48px;

        font-size:15px;
    }

}


/* ================================
   SMALL MOBILE
================================ */

@media(max-width:360px){

    body{
        padding:7px;
    }

    h2{
        padding:13px;

        font-size:17px;
    }

    form{
        padding:13px;
    }

}

.cancel-btn{
    display:block;
    width:100%;

    margin-top:10px;
    padding:13px;

    background:#eee;
    color:#555;

    border-radius:9px;

    text-align:center;
    text-decoration:none;

    font-size:14px;
    font-weight:bold;
}

.cancel-btn:hover{
    background:#ddd;
}

</style>

</head>

<body>

<h2>Register Company</h2>

<form method="POST" action="/register-company">

<label>Company Name</label>
<br>
<input type="text" name="name" required>
<br><br>

<label>Email</label>
<br>
<input type="email" name="email" required>
<br><br>

<label>State</label>
<br>

<select
    name="stateName"
    id="stateName"
    required
>

<option value="">
Select State
</option>

<% states.forEach(function(s){ %>

<option value="<%= s.state %>">
<%= s.state %>
</option>

<% }) %>

</select>

<br><br>

<label>Primary District</label>
<br>

<select
    name="primaryDistrict"
    id="primaryDistrict"
    required
>

<option value="">
Select District
</option>

</select>

<br><br>

<label>Subscription Period</label>
<br>

<select
    name="subscriptionMonths"
    required
>

<option value="3">
3 Months
</option>

<option value="6">
6 Months
</option>

<option value="12" selected>
12 Months
</option>

<option value="24">
24 Months
</option>

<option value="36">
36 Months
</option>

<option value="60">
60 Months
</option>

</select>

<br><br>

<label>Company Type</label>
<br>

<select
    name="companyType"
    required
>
    <option value="Real Estate Agency" selected>
        Real Estate Agency
    </option>

    <option value="Builder">
        Builder
    </option>

    <option value="Developer">
        Developer
    </option>

    <option value="Channel Partner">
        Channel Partner
    </option>

    <option value="Broker">
        Broker
    </option>

    <option value="Property Consultant">
        Property Consultant
    </option>

    <option value="Individual">
        Individual
    </option>

</select>

<br><br>

<label>Initial AI Credits</label>
<br>

<input
    type="number"
    name="credits"
    value="100"
    min="0"
    step="1"
    required
>

<br><br>


<h3>Admin User</h3>

<label>Admin Name</label>
<br>
<input
    type="text"
    name="adminName"
    required
>
<br><br>

<label>Admin Email</label>
<br>
<input
    type="email"
    name="adminEmail"
    required
>
<br><br>

<label>Password</label>
<br>
<input
    type="password"
    name="password"
    required
>

<br><br>

<button type="submit">Register</button>

<br><br>

<a href="/saas/dashboard" class="cancel-btn">
    Cancel
</a>

</form>

</body>

<script>

const states =
<%- JSON.stringify(states) %>

document
.getElementById('stateName')
.addEventListener('change', function(){

const stateName = this.value

const districtDropdown =
document.getElementById(
    'primaryDistrict'
)

districtDropdown.innerHTML =
'<option value="">Select District</option>'

const selectedState =
states.find(
s => s.state === stateName
)

if(!selectedState) return

selectedState.districts.forEach(
district => {

const option =
document.createElement('option')

option.value = district

option.textContent = district

districtDropdown.appendChild(option)

})

})

</script>

</html>