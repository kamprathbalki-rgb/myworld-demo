<!DOCTYPE html>
<html>
<head>

<title>Buyer Property Map</title>

<link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css"/>

<style>

#map{
height:600px;
width:100%;
}

</style>

</head>

<body>

<h3>Search Radius: <span id="radiusValue">1000</span> meters</h3>

<input type="range" id="radiusSlider" min="500" max="10000" step="500" value="1000">
<br><br>


<div id="map"></div>

<script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

<script>

var buyerLat = 18.5204
var buyerLng = 73.8567
var radius = 1000

var buyerId = "<%= typeof buyerId !== 'undefined' ? buyerId : '' %>"

var map = L.map('map').setView([buyerLat,buyerLng],15)

var slider = document.getElementById("radiusSlider")

slider.addEventListener("input",function(){

radius = parseInt(this.value)

document.getElementById("radiusValue").innerText = radius

circle.setRadius(radius)

loadProperties(buyerLat,buyerLng)

})

L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',{
maxZoom:19
}).addTo(map)

var buyerMarker = L.marker([buyerLat,buyerLng]).addTo(map)

var circle = L.circle([buyerLat,buyerLng],{
radius:radius,
color:'blue',
fillOpacity:0.2
}).addTo(map)

map.fitBounds(circle.getBounds())

var propertyMarkers = []

function loadProperties(lat,lng){

propertyMarkers.forEach(m => map.removeLayer(m))
propertyMarkers = []

fetch('/property/map-radius/'+lng+'/'+lat+'/'+radius)
.then(res=>res.json())
.then(data=>{

data.forEach(p=>{

var plat = p.location.coordinates[1]
var plng = p.location.coordinates[0]

var marker = L.marker([plat,plng])
.addTo(map)
.bindPopup(
"<b>"+p.title+"</b><br>"+
"Price: "+p.price+"<br><br>"+
"<button onclick='scheduleVisit(\""+p._id+"\")'>Schedule Visit</button>"
)

propertyMarkers.push(marker)

})

})

}

loadProperties(buyerLat,buyerLng)

map.on('click',function(e){

buyerLat = e.latlng.lat
buyerLng = e.latlng.lng

buyerMarker.setLatLng([buyerLat,buyerLng])

circle.setLatLng([buyerLat,buyerLng])

loadProperties(buyerLat,buyerLng)

})

function scheduleVisit(propertyId){

if(!buyerId){
alert("Open this map from a buyer page to schedule visit")
return
}

var executive = prompt("Enter Executive Name")

fetch('/visit/schedule',{
method:'POST',
headers:{
'Content-Type':'application/json'
},
body:JSON.stringify({
propertyId:propertyId,
buyerId:buyerId,
executiveName:executive,
visitDate:new Date()
})
})
.then(res=>res.json())
.then(data=>{
alert("Visit Scheduled")
})

}

</script>

</body>

</html>