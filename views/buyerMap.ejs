<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width, initial-scale=1.0"
>

<title>Buyer Property Map</title>


<link
rel="stylesheet"
href="https://unpkg.com/leaflet/dist/leaflet.css"
/>


<style>

*{
    box-sizing:border-box;
}

html,
body{
    margin:0;

    padding:0;

    height:100%;

    font-family:
    Arial,
    sans-serif;

    background:#f5f7fa;

    color:#333;
}


/* ================================
   PAGE
================================ */

.page{
    height:100vh;

    display:flex;

    flex-direction:column;
}


/* ================================
   HEADER
================================ */

.map-header{
    position:relative;

    z-index:1000;

    display:flex;

    justify-content:space-between;
    align-items:center;

    gap:15px;

    padding:12px 18px;

    background:white;

    box-shadow:
    0 2px 8px rgba(0,0,0,.12);
}

.header-info h1{
    margin:0;

    color:#1f4e79;

    font-size:21px;
}

.header-info p{
    margin:4px 0 0;

    color:#777;

    font-size:11px;
}

.header-actions{
    display:flex;

    gap:7px;
}

.header-btn{
    display:inline-block;

    padding:9px 12px;

    border-radius:7px;

    color:white;

    text-decoration:none;

    font-size:11px;

    font-weight:bold;

    white-space:nowrap;
}

.back-btn{
    background:#6c757d;
}

.home-btn{
    background:#1f4e79;
}


/* ================================
   CONTROLS
================================ */

.map-controls{
    position:relative;

    z-index:900;

    display:flex;

    align-items:center;

    gap:15px;

    padding:10px 18px;

    background:#f8fafc;

    border-bottom:
    1px solid #ddd;
}

.radius-info{
    min-width:190px;

    color:#555;

    font-size:12px;

    font-weight:bold;
}

.radius-info strong{
    color:#1f4e79;

    font-size:15px;
}

.slider-wrapper{
    flex:1;

    display:flex;

    align-items:center;

    gap:10px;
}

.slider-label{
    color:#777;

    font-size:10px;

    white-space:nowrap;
}

#radiusSlider{
    width:100%;

    cursor:pointer;
}

.map-help{
    color:#777;

    font-size:10px;

    white-space:nowrap;
}


/* ================================
   MAP
================================ */

#map{
    flex:1;

    width:100%;

    min-height:400px;
}


/* ================================
   LEAFLET POPUP
================================ */

.leaflet-popup-content{
    font-family:
    Arial,
    sans-serif;

    font-size:12px;

    line-height:1.5;
}

.leaflet-popup-content button{
    width:100%;

    margin-top:5px;

    padding:8px 10px;

    border:none;

    border-radius:6px;

    background:#1f4e79;

    color:white;

    cursor:pointer;

    font-size:11px;

    font-weight:bold;
}


/* ================================
   MOBILE
================================ */

@media(max-width:700px){

    .map-header{
        display:block;

        padding:10px;
    }

    .header-info h1{
        font-size:18px;
    }

    .header-info p{
        font-size:10px;
    }

    .header-actions{
        display:grid;

        grid-template-columns:
        1fr 1fr;

        gap:6px;

        margin-top:9px;
    }

    .header-btn{
        padding:8px 5px;

        text-align:center;

        font-size:10px;
    }

    .map-controls{
        display:block;

        padding:9px 10px;
    }

    .radius-info{
        min-width:0;

        margin-bottom:8px;

        font-size:11px;
    }

    .radius-info strong{
        font-size:13px;
    }

    .slider-wrapper{
        width:100%;
    }

    .map-help{
        margin-top:7px;

        white-space:normal;

        line-height:1.4;
    }

    #map{
        min-height:350px;
    }

}

</style>

</head>


<body>


<div class="page">


<!-- ================================
     HEADER
================================ -->

<div class="map-header">


<div class="header-info">

<h1>
Buyer Property Map
</h1>

<p>
View properties within the selected search radius
</p>

</div>


<div class="header-actions">


<a
href="javascript:history.back()"
class="header-btn back-btn"
>
← Back
</a>


<a
href="/dashboard"
class="header-btn home-btn"
>
Home
</a>


</div>


</div>



<!-- ================================
     RADIUS CONTROLS
================================ -->

<div class="map-controls">


<div class="radius-info">

Search Radius:

<strong>

<span id="radiusValue">
1000
</span>

meters

</strong>

</div>



<div class="slider-wrapper">


<span class="slider-label">
500 m
</span>


<input
type="range"
id="radiusSlider"
min="500"
max="10000"
step="500"
value="1000"
>


<span class="slider-label">
10 km
</span>


</div>



<div class="map-help">

Click anywhere on the map to move the buyer search point.

</div>


</div>



<!-- ================================
     MAP
================================ -->

<div id="map"></div>


</div>



<script
src="https://unpkg.com/leaflet/dist/leaflet.js"
></script>


<script>


var buyerLat =
18.5204


var buyerLng =
73.8567


var radius =
1000


var buyerId =
"<%= typeof buyerId !== 'undefined' ? buyerId : '' %>"



/* ================================
   INITIALISE MAP
================================ */

var map =
L.map(
    'map'
)
.setView(
    [
        buyerLat,
        buyerLng
    ],
    15
)



/* ================================
   MAP TILES
================================ */

L.tileLayer(
'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',
{

    maxZoom:19

}
)
.addTo(
    map
)



/* ================================
   BUYER MARKER
================================ */

var buyerMarker =
L.marker(
    [
        buyerLat,
        buyerLng
    ]
)
.addTo(
    map
)



/* ================================
   SEARCH RADIUS CIRCLE
================================ */

var circle =
L.circle(
[
    buyerLat,
    buyerLng
],
{

    radius:radius,

    color:'blue',

    fillOpacity:0.2

}
)
.addTo(
    map
)


map.fitBounds(
    circle.getBounds()
)



/* ================================
   PROPERTY MARKERS
================================ */

var propertyMarkers =
[]



function loadProperties(
    lat,
    lng
){


    propertyMarkers
    .forEach(
        m =>
        map.removeLayer(m)
    )


    propertyMarkers =
    []


    fetch(
        '/property/map-radius/'
        +
        lng
        +
        '/'
        +
        lat
        +
        '/'
        +
        radius
    )


    .then(
        res =>
        res.json()
    )


    .then(
        data => {


            data.forEach(
                p => {


                    var plat =
                    p.location
                    .coordinates[1]


                    var plng =
                    p.location
                    .coordinates[0]


                    var marker =
                    L.marker(
                        [
                            plat,
                            plng
                        ]
                    )


                    .addTo(
                        map
                    )


                    .bindPopup(

                        "<b>"
                        +
                        p.title
                        +
                        "</b><br>"
                        +

                        "Price: "
                        +
                        p.price
                        +
                        "<br><br>"
                        +

                        "<button onclick='scheduleVisit(\""
                        +
                        p._id
                        +
                        "\")'>Schedule Visit</button>"

                    )


                    propertyMarkers
                    .push(
                        marker
                    )


                }
            )


        }
    )


}



/* ================================
   INITIAL PROPERTY LOAD
================================ */

loadProperties(
    buyerLat,
    buyerLng
)



/* ================================
   RADIUS SLIDER
================================ */

var slider =
document
.getElementById(
    "radiusSlider"
)


slider
.addEventListener(
"input",
function(){


    radius =
    parseInt(
        this.value
    )


    document
    .getElementById(
        "radiusValue"
    )
    .innerText =
    radius


    circle
    .setRadius(
        radius
    )


    loadProperties(
        buyerLat,
        buyerLng
    )


}
)



/* ================================
   MOVE BUYER LOCATION
================================ */

map.on(
'click',
function(e){


    buyerLat =
    e.latlng.lat


    buyerLng =
    e.latlng.lng


    buyerMarker
    .setLatLng(
        [
            buyerLat,
            buyerLng
        ]
    )


    circle
    .setLatLng(
        [
            buyerLat,
            buyerLng
        ]
    )


    loadProperties(
        buyerLat,
        buyerLng
    )


}
)



/* ================================
   SCHEDULE VISIT
================================ */

function scheduleVisit(
    propertyId
){


    if(
        !buyerId
    ){

        alert(
            "Open this map from a buyer page to schedule visit"
        )

        return

    }


    var executive =
    prompt(
        "Enter Executive Name"
    )


    fetch(
    '/visit/schedule',
    {

        method:
        'POST',

        headers:
        {

            'Content-Type':
            'application/json'

        },

        body:
        JSON.stringify(
        {

            propertyId:
            propertyId,

            buyerId:
            buyerId,

            executiveName:
            executive,

            visitDate:
            new Date()

        }
        )

    }
    )


    .then(
        res =>
        res.json()
    )


    .then(
        data => {

            alert(
                "Visit Scheduled"
            )

        }
    )


}


</script>


</body>

</html>