<!DOCTYPE html>
<html>

<head>

<title>Demand Prediction</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#f4f6f9;
}

.card{
padding:20px;
background:white;
border-radius:10px;
box-shadow:0 2px 6px rgba(0,0,0,0.1);
}

</style>

</head>

<body>

<div class="container">

<h2 class="my-4">AI Property Demand Prediction</h2>

<div class="row">

<div class="col-md-6">
<div class="card">
<canvas id="bedroomChart"></canvas>
</div>
</div>

<div class="col-md-6">
<div class="card">
<canvas id="budgetChart"></canvas>
</div>
</div>

</div>

</div>

<script>

const bedroomLabels = <%- JSON.stringify(topBedrooms.map(b=>b._id)) %>
const bedroomData = <%- JSON.stringify(topBedrooms.map(b=>b.count)) %>

new Chart(document.getElementById('bedroomChart'),{

type:'bar',

data:{
labels:bedroomLabels,
datasets:[{
label:'Most Demanded Bedrooms',
data:bedroomData
}]
}

})


const budgetLabels = <%- JSON.stringify(budgetRanges.map(b=>b._id)) %>
const budgetData = <%- JSON.stringify(budgetRanges.map(b=>b.count)) %>

new Chart(document.getElementById('budgetChart'),{

type:'pie',

data:{
labels:budgetLabels,
datasets:[{
label:'Budget Demand',
data:budgetData
}]
}

})

</script>

</body>

</html>