<!DOCTYPE html>
<html>

<head>

<title>Smart Property Recommendations</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#f4f6f9;
}

.card{
margin-bottom:15px;
padding:20px;
border-radius:10px;
box-shadow:0 2px 6px rgba(0,0,0,0.1);
}

.score{
font-size:22px;
font-weight:bold;
color:#2ecc71;
}

</style>

</head>

<body>

<a href="javascript:history.back()">Back</a> |

<a href="/dashboard">Home</a> |

<a href="/logout">Logout</a>

<hr>

<div class="container">

<h2 class="my-4">
Smart Property Recommendations for <%= buyer.name %>
</h2>

<% properties.forEach(function(r){ %>

<div class="card">

<h5><%= r.property.title %></h5>

<p>
City: <%= r.property.city %><br>
Bedrooms: <%= r.property.bedrooms %><br>
Area: <%= r.property.area %> sq.ft<br>
Price: ₹ <%= r.property.price %>
</p>

<div class="score">
Match Score: <%= r.score %>
</div>

</div>

<% }) %>

</div>

</body>

</html>