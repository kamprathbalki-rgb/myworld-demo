<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width, initial-scale=1.0"
>

<title>Change Password</title>

<style>

*{
    box-sizing:border-box;
}

body{
    margin:0;
    padding:20px;
    font-family:Arial,sans-serif;
    background:#f5f7fa;
    color:#333;
}

.container{
    max-width:600px;
    margin:auto;
}

.page-header{
    margin-bottom:20px;
    padding:18px 20px;
    background:white;
    border-radius:12px;
    box-shadow:0 2px 8px rgba(0,0,0,.08);
}

.page-header h1{
    margin:0;
    color:#1f4e79;
    font-size:25px;
}

.page-header p{
    margin:6px 0 0;
    color:#777;
    font-size:13px;
}

.form-card{
    padding:22px;
    background:white;
    border-radius:12px;
    box-shadow:0 2px 8px rgba(0,0,0,.08);
}

.form-group{
    display:flex;
    flex-direction:column;
    gap:6px;
    margin-bottom:18px;
}

.form-group label{
    color:#555;
    font-size:12px;
    font-weight:bold;
}

.form-control{
    width:100%;
    min-height:44px;
    padding:10px;
    border:1px solid #ccc;
    border-radius:6px;
    font-size:14px;
}

.form-control:focus{
    outline:none;
    border-color:#1f4e79;
    box-shadow:0 0 0 2px rgba(31,78,121,.08);
}

.form-actions{
    display:flex;
    justify-content:flex-end;
    gap:10px;
    margin-top:22px;
}

.cancel-btn,
.save-btn{
    min-width:130px;
    padding:12px 18px;
    border:none;
    border-radius:7px;
    font-size:13px;
    font-weight:bold;
    text-align:center;
}

.cancel-btn{
    background:#6c757d;
    color:white;
    text-decoration:none;
}

.save-btn{
    background:#28a745;
    color:white;
    cursor:pointer;
}

.save-btn:hover{
    background:#218838;
}

@media(max-width:700px){

    body{
        padding:10px;
    }

    .page-header{
        padding:14px;
        margin-bottom:12px;
    }

    .page-header h1{
        font-size:20px;
    }

    .page-header p{
        font-size:11px;
    }

    .form-card{
        padding:16px;
    }

    .form-actions{
        display:grid;
        grid-template-columns:1fr 1fr;
        gap:8px;
    }

    .cancel-btn,
    .save-btn{
        width:100%;
        min-width:0;
    }

}

</style>

</head>


<body>

<div class="container">

<div class="page-header">

<h1>
Change Password
</h1>

<p>
Update your account password
</p>

</div>


<div class="form-card">

<form
method="POST"
action="/change-password"
>


<div class="form-group">

<label>
Current Password
</label>

<input
type="password"
name="currentPassword"
class="form-control"
required
>

</div>


<div class="form-group">

<label>
New Password
</label>

<input
type="password"
name="newPassword"
class="form-control"
required
>

</div>


<div class="form-actions">

<a
href="javascript:history.back()"
class="cancel-btn"
>
Cancel
</a>

<button
type="submit"
class="save-btn"
>
Change Password
</button>

</div>


</form>

</div>

</div>

</body>

</html>