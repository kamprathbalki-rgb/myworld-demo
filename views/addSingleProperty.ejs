<!DOCTYPE html>
<html>

<head>

<meta charset="UTF-8">

<meta
name="viewport"
content="width=device-width, initial-scale=1.0"
>

<title>Add Single Property</title>

<style>

*{
    box-sizing:border-box;
}

body{
    margin:0;
    padding:20px;

    font-family:Arial,sans-serif;

    background:#f5f7fa;

    color:#333;
}

.container{
    max-width:1000px;

    margin:auto;
}


/* ================================
   HEADER
================================ */

.page-header{
    display:flex;

    justify-content:space-between;
    align-items:center;

    gap:15px;

    margin-bottom:20px;

    padding:18px 20px;

    background:white;

    border-radius:12px;

    box-shadow:
    0 2px 8px rgba(0,0,0,.08);
}

.header-info h1{
    margin:0;

    color:#1f4e79;

    font-size:25px;
}

.header-info p{
    margin:6px 0 0;

    color:#777;

    font-size:13px;
}

.header-actions{
    display:flex;

    flex-wrap:wrap;

    gap:8px;
}

.header-btn{
    display:inline-block;

    padding:10px 14px;

    border-radius:7px;

    color:white;

    text-decoration:none;

    font-size:12px;

    font-weight:bold;

    white-space:nowrap;
}

.back-btn{
    background:#6c757d;
}

.home-btn{
    background:#1f4e79;
}


/* ================================
   ERROR
================================ */

.error-message{
    margin-bottom:18px;

    padding:12px 15px;

    background:#ffebee;

    color:#c62828;

    border:1px solid #ffcdd2;

    border-left:4px solid #dc3545;

    border-radius:8px;

    font-size:13px;

    font-weight:bold;
}


/* ================================
   FORM SECTION
================================ */

.form-section{
    margin-bottom:18px;

    padding:20px;

    background:white;

    border-radius:12px;

    box-shadow:
    0 2px 8px rgba(0,0,0,.08);
}

.section-title{
    margin:0 0 18px;

    padding-bottom:10px;

    border-bottom:1px solid #eee;

    color:#1f4e79;

    font-size:18px;
}

.section-note{
    margin:-5px 0 18px;

    color:#777;

    font-size:12px;

    line-height:1.5;
}


/* ================================
   FORM GRID
================================ */

.form-grid{
    display:grid;

    grid-template-columns:
    repeat(2,1fr);

    gap:16px 20px;
}

.form-group{
    display:flex;

    flex-direction:column;

    gap:6px;
}

.form-group.full-width{
    grid-column:1 / -1;
}

.form-group label{
    color:#555;

    font-size:12px;

    font-weight:bold;
}

.form-control{
    width:100%;

    min-height:42px;

    padding:9px 10px;

    border:1px solid #ccc;

    border-radius:6px;

    background:white;

    color:#333;

    font-family:Arial,sans-serif;

    font-size:13px;
}

.form-control:focus{
    outline:none;

    border-color:#1f4e79;

    box-shadow:
    0 0 0 2px rgba(31,78,121,.08);
}

textarea.form-control{
    min-height:100px;

    resize:vertical;
}


/* ================================
   FILE UPLOAD
================================ */

.file-input{
    padding:8px;

    background:#f8fafc;
}


/* ================================
   ADVANCED LOCATION
================================ */

.advanced-section{
    margin-bottom:18px;

    padding:0;

    background:white;

    border-radius:12px;

    box-shadow:
    0 2px 8px rgba(0,0,0,.08);

    overflow:hidden;
}

.advanced-section summary{
    padding:17px 20px;

    color:#1f4e79;

    cursor:pointer;

    font-size:15px;

    font-weight:bold;

    list-style-position:inside;
}

.advanced-section summary:hover{
    background:#f8fafc;
}

.advanced-content{
    padding:5px 20px 20px;

    border-top:1px solid #eee;
}


/* ================================
   FORM ACTIONS
================================ */

.form-actions{
    display:flex;

    justify-content:flex-end;

    gap:10px;

    margin-top:5px;
}

.cancel-btn{
    display:inline-block;

    min-width:110px;

    padding:12px 18px;

    background:#6c757d;

    color:white;

    text-align:center;

    text-decoration:none;

    border-radius:7px;

    font-size:13px;

    font-weight:bold;
}

.save-btn{
    min-width:180px;

    padding:12px 20px;

    border:none;

    border-radius:7px;

    background:#28a745;

    color:white;

    cursor:pointer;

    font-size:13px;

    font-weight:bold;
}

.save-btn:hover{
    background:#218838;
}


/* ================================
   MOBILE
================================ */

@media(max-width:700px){

    body{
        padding:10px;
    }


    .page-header{
        display:block;

        padding:14px;

        margin-bottom:12px;
    }


    .header-info h1{
        font-size:20px;
    }


    .header-info p{
        font-size:11px;
    }


    .header-actions{
        display:grid;

        grid-template-columns:
        1fr 1fr;

        gap:6px;

        margin-top:12px;
    }


    .header-btn{
        padding:9px 5px;

        text-align:center;

        font-size:10px;
    }


    .form-section{
        margin-bottom:12px;

        padding:14px;
    }


    .section-title{
        margin-bottom:14px;

        font-size:16px;
    }


    .form-grid{
        grid-template-columns:1fr;

        gap:13px;
    }


    .form-group.full-width{
        grid-column:auto;
    }


    .form-control{
        min-height:44px;

        font-size:14px;
    }


    .advanced-section{
        margin-bottom:12px;
    }


    .advanced-section summary{
        padding:15px;

        font-size:14px;
    }


    .advanced-content{
        padding:5px 14px 14px;
    }


    .form-actions{
        display:grid;

        grid-template-columns:1fr 1fr;

        gap:8px;
    }


    .cancel-btn,
    .save-btn{
        width:100%;

        min-width:0;

        text-align:center;
    }

}

</style>

</head>


<body>


<div class="container">


<!-- ================================
     HEADER
================================ -->

<div class="page-header">


<div class="header-info">

<h1>
Add Single Property
</h1>

<p>
Add an individual property to your inventory
</p>

</div>


<div class="header-actions">


<a
href="javascript:history.back()"
class="header-btn back-btn"
>
← Back
</a>


<a
href="/dashboard"
class="header-btn home-btn"
>
Home
</a>


</div>


</div>



<!-- ================================
     FORM
================================ -->

<form
method="POST"
action="/property/save"
enctype="multipart/form-data"
>


<% if(error){ %>

<div class="error-message">

<%= error %>

</div>

<% } %>


<input
type="hidden"
name="propertyMode"
value="SINGLE"
>



<!-- ================================
     OWNER DETAILS
================================ -->

<div class="form-section">


<h2 class="section-title">
Owner Details
</h2>


<div class="form-grid">


<div class="form-group">

<label>
Owner Name
</label>

<input
type="text"
name="ownerName"
class="form-control"
required
>

</div>


<div class="form-group">

<label>
Owner Mobile
</label>

<input
type="tel"
name="ownerMobile"
class="form-control"
pattern="[0-9]{10}"
maxlength="10"
minlength="10"
placeholder="10 digit mobile number"
required
>

</div>


</div>


</div>



<!-- ================================
     PRICING
================================ -->

<div class="form-section">


<h2 class="section-title">
Pricing
</h2>


<div class="form-grid">


<div class="form-group">

<label>
Carpet Area (Sq Ft)
</label>

<input
type="number"
step="1"
name="singleCarpetArea"
class="form-control"
required
placeholder="e.g. 850"
>

</div>


<div class="form-group">

<label>
Builder / Owner Asking Price (Lakhs)
</label>

<input
type="number"
step="0.01"
name="askingPrice"
class="form-control"
required
>

</div>


<div class="form-group">

<label>
Expected Closing Price (Lakhs)
</label>

<input
type="number"
step="0.01"
name="expectedClosingPrice"
class="form-control"
>

</div>


</div>


</div>



<!-- ================================
     RENTAL / LEASE DETAILS
================================ -->

<div class="form-section">


<h2 class="section-title">
Rental / Lease Details
</h2>


<p class="section-note">
Complete these fields when the property is available for rent or lease.
</p>


<div class="form-grid">


<div class="form-group">

<label>
Monthly Rent
</label>

<input
type="number"
name="monthlyRent"
class="form-control"
placeholder="e.g. 25000"
>

</div>


<div class="form-group">

<label>
Security Deposit
</label>

<input
type="number"
name="securityDeposit"
class="form-control"
placeholder="e.g. 75000"
>

</div>


<div class="form-group">

<label>
Maintenance Charges
</label>

<input
type="number"
name="maintenanceCharges"
class="form-control"
placeholder="e.g. 3000"
>

</div>


<div class="form-group">

<label>
Lease Duration (Months)
</label>

<input
type="number"
name="leaseDurationMonths"
class="form-control"
placeholder="e.g. 11"
>

</div>


</div>


</div>



<!-- ================================
     PROPERTY DETAILS
================================ -->

<div class="form-section">


<h2 class="section-title">
Property Details
</h2>


<div class="form-grid">


<div class="form-group">

<label>
Property Status
</label>

<select
name="propertyStatus"
class="form-control"
>

<option
value="Available"
selected
>
Available
</option>

<option value="Blocked">
Blocked
</option>

<option value="Sold">
Sold
</option>

</select>

</div>



<div class="form-group">

<label>
Transaction Type
</label>

<select
name="transactionType"
class="form-control"
>

<option value="SALE">
Sale
</option>

<option value="RENT">
Rent
</option>

<option value="LEASE">
Lease
</option>

</select>

</div>



<div class="form-group">

<label>
Floor Number
</label>

<input
type="number"
name="floorNumber"
class="form-control"
min="0"
>

</div>



<div class="form-group">

<label>
Total Floors
</label>

<input
type="number"
name="totalFloors"
class="form-control"
min="1"
>

</div>



<div class="form-group">

<label>
Facing
</label>

<select
name="facing"
class="form-control"
>

<option value="">
Select Facing
</option>

<option>
East
</option>

<option>
West
</option>

<option>
North
</option>

<option>
South
</option>

<option>
North-East
</option>

<option>
North-West
</option>

<option>
South-East
</option>

<option>
South-West
</option>

</select>

</div>



<div class="form-group">

<label>
Lift Available
</label>

<select
name="liftAvailable"
class="form-control"
>

<option value="">
Select
</option>

<option value="Yes">
Yes
</option>

<option value="No">
No
</option>

</select>

</div>



<div class="form-group">

<label>
Property Age (Years)
</label>

<input
type="number"
name="propertyAge"
class="form-control"
min="0"
placeholder="e.g. 5"
>

</div>



<div class="form-group">

<label>
Property Status
</label>

<select
name="propertyStatus"
class="form-control"
>

<option value="Available">
Available
</option>

<option value="Token Received">
Token Received
</option>

<option value="Agreement Done">
Agreement Done
</option>

<option value="Sold">
Sold
</option>

</select>

</div>



<div class="form-group">

<label>
Furnished Status
</label>

<select
name="furnishedStatus"
class="form-control"
>

<option>
Unfurnished
</option>

<option>
Semi-Furnished
</option>

<option>
Fully Furnished
</option>

</select>

</div>



<div class="form-group">

<label>
Possession Status
</label>

<select
name="possessionStatus"
class="form-control"
>

<option value="">
Select
</option>

<option>
Immediate
</option>

<option>
Ready Possession
</option>

<option>
Under Construction
</option>

<option>
Possession Soon
</option>

</select>

</div>



<div class="form-group full-width">

<label>
Parking Type
</label>

<select
name="parkingType"
class="form-control"
>

<option value="">
Select
</option>

<option>
Open
</option>

<option>
Covered
</option>

<option>
Basement
</option>

<option>
Podium
</option>

<option>
Stilt
</option>

</select>

</div>


</div>


</div>



<!-- ================================
     PROPERTY BASICS
================================ -->

<div class="form-section">


<h2 class="section-title">
Property Basics
</h2>


<div class="form-grid">


<div class="form-group">

<label>
Property Name
</label>

<input
type="text"
name="projectName"
class="form-control"
required
>

</div>



<div class="form-group">

<label>
Builder / Society / Source
</label>

<input
type="text"
name="builderName"
class="form-control"
>

</div>



<div class="form-group full-width">

<label>
Location
</label>

<select
name="propertyLocation"
class="form-control"
required
>


<option value="">
Select Location
</option>


<% locations.forEach(function(location){ %>


<option value="<%= location.officeName %>">

<%= location.officeName %>

(

<%= location.district %>

)

</option>


<% }) %>


</select>

</div>



<div class="form-group">

<label>
Project Status
</label>

<select
name="projectStatus"
class="form-control"
>

<option value="">
Select
</option>

<option>
New Launch
</option>

<option>
Under Construction
</option>

<option>
Ready Possession
</option>

<option>
Resale
</option>

</select>

</div>



<div class="form-group">

<label>
Property Type
</label>

<select
name="propertyType"
class="form-control"
required
>

<option>
Apartment
</option>

<option>
Villa
</option>

<option>
Plot
</option>

<option>
Office
</option>

<option>
Showroom
</option>

<option>
Retail
</option>

<option>
Shop
</option>

</select>

</div>



<div class="form-group">

<label>
RERA Approved
</label>

<select
name="reraApproved"
class="form-control"
>

<option value="">
Select
</option>

<option>
Yes
</option>

<option>
No
</option>

</select>

</div>



<div class="form-group">

<label>
Number of Buildings / Towers
</label>

<input
type="number"
name="numberOfTowers"
class="form-control"
>

</div>



<div class="form-group">

<label>
Flat Type
</label>

<select
name="singleFlatType"
class="form-control"
required
>

<option>
Studio
</option>

<option>
1 RK
</option>

<option>
1 BHK
</option>

<option>
1.5 BHK
</option>

<option>
2 BHK
</option>

<option>
2.5 BHK
</option>

<option>
3 BHK
</option>

<option>
3.5 BHK
</option>

<option>
4 BHK
</option>

<option>
4.5 BHK
</option>

<option>
5 BHK
</option>

<option>
5+ BHK
</option>

<option>
Villa
</option>

<option>
Plot
</option>

<option>
Office
</option>

<option>
Showroom
</option>

<option>
Retail
</option>

<option>
Shop
</option>

</select>

</div>



<div class="form-group">

<label>
Cover Photo
</label>

<input
type="file"
name="coverPhoto"
class="form-control file-input"
accept="image/*"
>

</div>


</div>


</div>



<!-- ================================
     ADVANCED LOCATION DETAILS
================================ -->

<details class="advanced-section">


<summary>
Advanced Location Details
</summary>


<div class="advanced-content">


<div class="form-grid">


<div class="form-group full-width">

<label>
Google Pin
</label>

<input
type="text"
name="googlePin"
class="form-control"
>

</div>



<div class="form-group">

<label>
Longitude
</label>

<input
type="text"
name="lng"
class="form-control"
>

</div>



<div class="form-group">

<label>
Latitude
</label>

<input
type="text"
name="lat"
class="form-control"
>

</div>


</div>


</div>


</details>



<!-- ================================
     MARKETING NOTES
================================ -->

<div class="form-section">


<h2 class="section-title">
Marketing Notes
</h2>


<div class="form-grid">


<div class="form-group full-width">

<label>
Amenities
</label>

<textarea
name="amenities"
class="form-control"
></textarea>

</div>



<div class="form-group full-width">

<label>
USP
</label>

<textarea
name="usp"
class="form-control"
></textarea>

</div>



<div class="form-group full-width">

<label>
Notes
</label>

<textarea
name="notes"
class="form-control"
></textarea>

</div>


</div>


</div>



<!-- ================================
     ACTIONS
================================ -->

<div class="form-actions">


<a
href="javascript:history.back()"
class="cancel-btn"
>
Cancel
</a>


<button
type="submit"
class="save-btn"
>
Save Single Property
</button>


</div>


</form>


</div>


</body>

</html>