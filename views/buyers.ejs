<!DOCTYPE html>
<html>
<head>
<title>Buyers</title>

<style>

.summary{
display:flex;
gap:15px;
margin-top:15px;
margin-bottom:20px;
flex-wrap:wrap;
}

.card{
border:1px solid #ccc;
padding:15px;
width:140px;
text-align:center;
}

.card h3{
margin:0;
font-size:14px;
}

.card h2{
margin:10px 0 0 0;
}

</style>

</head>

<body>

<a href="javascript:history.back()">Back</a> |
<a href="/dashboard">Home</a> |
<a href="/logout">Logout</a>

<hr>

<h1>Buyer List</h1>


<div class="summary">

<a href="/buyer/page?status=New Lead" style="text-decoration:none;color:black;">
<div class="card">
<h3>New Leads</h3>
<h2><%= newLeads %></h2>
</div>
</a>

<a href="/buyer/page?status=Contacted" style="text-decoration:none;color:black;">
<div class="card">
<h3>Contacted</h3>
<h2><%= contacted %></h2>
</div>
</a>

<a href="/buyer/page?status=Site Visit" style="text-decoration:none;color:black;">
<div class="card">
<h3>Site Visits</h3>
<h2><%= siteVisits %></h2>
</div>
</a>

<a href="/buyer/page?status=Negotiation" style="text-decoration:none;color:black;">
<div class="card">
<h3>Negotiation</h3>
<h2><%= negotiations %></h2>
</div>
</a>

<a href="/buyer/page?status=Deal Closed" style="text-decoration:none;color:black;">
<div class="card">
<h3>Closed</h3>
<h2><%= closedDeals %></h2>
</div>
</a>

<a href="/buyer/page?status=Lost" style="text-decoration:none;color:black;">
<div class="card">
<h3>Lost</h3>
<h2><%= lostDeals %></h2>
</div>
</a>

</div>

<br>

<form method="GET" action="/buyer/page">

<input
type="text"
name="search"
placeholder="Search Name / Phone / Location"
value="<%= search || '' %>"
>

<button type="submit">
Search
</button>

<button
type="button"
onclick="window.location='/buyer/page'">
Clear Search
</button>



<select name="status" onchange="this.form.submit()">

<option value="">All Status</option>

<option value="New Lead">New Lead</option>

<option value="Contacted">Contacted</option>

<option value="Site Visit">Site Visit</option>

<option value="Negotiation">Negotiation</option>

<option value="Deal Closed">Deal Closed</option>

<option value="Lost">Lost</option>

</select>



</form>

<br>

<table border="1">

<tr>
<th>Name</th>
<th>Phone</th>
<th>Budget</th>
<th>Required Possession</th>
<th>Required Flat Type</th>
<th>Preferred Locations</th>
<th>Primary Location</th>
<th>Assignment Type</th>
<th>Status</th>
<th>Visit Status</th>
<th>Last Activity</th>
<th>Follow Up</th>
<th>Notes</th>
<th>Matches</th>
<th>Actions</th>
<th>Assigned Executive</th>
<th>Reassign</th>
</tr>

<% buyers.forEach(function(b){ %>

<tr>

<td><%= b.name %></td>

<td><%= b.phone %></td>

<td>
<%= b.minBudget %> - <%= b.maxBudget %>
</td>

<td>
<%= b.requiredPossession && b.requiredPossession.length > 0
? b.requiredPossession.join(', ')
: '' %>
</td>

<td>
<%= b.requiredFlatType || '' %>
</td>

<td>
<%= b.preferredLocations && b.preferredLocations.length > 0
? b.preferredLocations.join(', ')
: '' %>
</td>

<td>
<%= b.primaryLocation || '' %>
</td>

<td>
<%= b.assignmentType || 'AUTO' %>
</td>

<td>

<form method="POST" action="/buyer/status/<%= b._id %>">

<select name="status" onchange="this.form.submit()">

<option value="New Lead" <%= b.status=="New Lead" ? "selected" : "" %>>
New Lead
</option>

<option value="Contacted" <%= b.status=="Contacted" ? "selected" : "" %>>
Contacted
</option>

<option value="Site Visit" <%= b.status=="Site Visit" ? "selected" : "" %>>
Site Visit
</option>

<option value="Negotiation" <%= b.status=="Negotiation" ? "selected" : "" %>>
Negotiation
</option>

<option value="Deal Closed" <%= b.status=="Deal Closed" ? "selected" : "" %>>
Deal Closed
</option>

<option value="Lost" <%= b.status=="Lost" ? "selected" : "" %>>
Lost
</option>

</select>

</form>

</td>

<td>
<%= b.latestVisitStatus || 'No Visit' %>
</td>

<td>
<%= b.lastActivity
? new Date(b.lastActivity).toLocaleString('en-IN')
: '-' %>
</td>

<td>

<form method="POST" action="/buyer/followup/<%= b._id %>">

<input
type="datetime-local"
name="nextFollowUp"
value="<%= b.nextFollowUp
? new Date(
    new Date(b.nextFollowUp).getTime()
    - new Date(b.nextFollowUp).getTimezoneOffset() * 60000
).toISOString().slice(0,16)
: '' %>"
>

</td>

<td>

<input
type="text"
name="followUpNotes"
value="<%= b.followUpNotes || '' %>"
>

<button type="submit">
Save
</button>

</form>

</td>

<td>

<a href="/buyer/matches/<%= b._id %>">
View Matches
</a>

</td>

<td>

<a href="/buyer/edit/<%= b._id %>">Edit</a>

|

<form
method="GET"
action="/buyer/delete/<%= b._id %>"
onsubmit="return confirm('Are you sure you want to delete this buyer?')"
style="display:inline;"
>

<button type="submit">
Delete
</button>

</form>

</td>

<td>
<%= b.assignedExecutiveName || 'Not Assigned' %>
</td>

<td>

<form method="POST" action="/buyer/reassign/<%= b._id %>">

<select name="executiveId" required>

<option value="">Select Executive</option>

<% executives.forEach(function(exec){ %>

<option value="<%= exec._id %>">
<%= exec.name %>
</option>

<% }) %>

</select>

<button type="submit">
Reassign
</button>

</form>

</td>

</tr>

<% }) %>

</table>

</body>
</html>