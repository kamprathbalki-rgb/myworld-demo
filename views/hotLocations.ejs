<!DOCTYPE html>
<html>

<head>

<title>Hot Locations</title>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#f4f6f9;
}

.hot{
background:#ff6b6b;
color:white;
}

.warm{
background:#feca57;
}

.cool{
background:#54a0ff;
color:white;
}

</style>

</head>

<body>

<div class="container">

<h2 class="my-4">Hot Location Detector</h2>

<table class="table table-bordered">

<tr>
<th>City</th>
<th>Buyer Demand</th>
<th>Visits</th>
<th>Deals</th>
<th>Score</th>
</tr>

<% locations.forEach(function(l){ %>

<tr class="<%= l.score>10?'hot':l.score>5?'warm':'cool' %>">

<td><%= l.city %></td>
<td><%= l.buyers %></td>
<td><%= l.visits %></td>
<td><%= l.deals %></td>
<td><%= l.score %></td>

</tr>

<% }) %>

</table>

</div>

</body>

</html>