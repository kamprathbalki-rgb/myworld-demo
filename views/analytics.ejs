<!DOCTYPE html>
<html>

<head>

<title>Analytics Dashboard</title>

<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">

<style>

body{
background:#f4f6f9;
font-family:Arial;
}

.card{
padding:20px;
border-radius:10px;
box-shadow:0 2px 6px rgba(0,0,0,0.1);
background:white;
}

</style>

</head>

<body>

<div class="container">

<h2 class="my-4">Analytics Dashboard</h2>

<div class="row">

<div class="col-md-6">
<div class="card">
<canvas id="visitsChart"></canvas>
</div>
</div>

<div class="col-md-6">
<div class="card">
<canvas id="dealsChart"></canvas>
</div>
</div>

</div>

</div>

<div class="row mt-4">

<div class="col-md-6">
<div class="card">
<canvas id="topCityChart"></canvas>
</div>
</div>

</div>

<script>

const visitLabels = <%- JSON.stringify(visits.map(v=>v._id)) %>
const visitData = <%- JSON.stringify(visits.map(v=>v.count)) %>

const dealLabels = <%- JSON.stringify(deals.map(v=>v._id)) %>
const dealData = <%- JSON.stringify(deals.map(v=>v.count)) %>


new Chart(document.getElementById('visitsChart'),{
type:'bar',
data:{
labels:visitLabels,
datasets:[{
label:'Visits per Month',
data:visitData
}]
}
})


new Chart(document.getElementById('dealsChart'),{
type:'line',
data:{
labels:dealLabels,
datasets:[{
label:'Deals per Month',
data:dealData
}]
}
})


const cityLabels = <%- JSON.stringify(topProperties.map(p=>p._id)) %>
const cityData = <%- JSON.stringify(topProperties.map(p=>p.visits)) %>

new Chart(document.getElementById('topCityChart'),{

type:'pie',

data:{
labels:cityLabels,
datasets:[{
label:'Visits by City',
data:cityData
}]
}

})

</script>

</body>

</html>